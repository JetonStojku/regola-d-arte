---
import PhotoPlaceholder from "@/components/PhotoPlaceholder.astro";

type Locale = "it" | "en";

type Props = {
  locale: Locale;
};

const { locale } = Astro.props as Props;

const copy = {
  it: {
    eyebrow: "Prima / Dopo",
    title: "Risultati da documentare solo con immagini approvate.",
    intro:
      "Questa sezione e pronta per casi clinici reali. Per ora usa segnaposto chiari, cosi le immagini possono essere scelte e sostituite senza cambiare il layout.",
    before: "Prima",
    after: "Dopo",
    beforeTitle: "Immagine pre-trattamento mancante",
    afterTitle: "Immagine post-trattamento mancante",
    beforeDescription:
      "Usare solo una foto approvata dello stesso caso, con angolo e luce coerenti.",
    afterDescription:
      "Usare solo una foto approvata dello stesso caso e della stessa inquadratura.",
    treatment: "Trattamento",
    note: "Non pubblicare foto cliniche prima di avere consenso, selezione definitiva e testo descrittivo verificato.",
  },
  en: {
    eyebrow: "Before / After",
    title: "Results must be documented only with approved images.",
    intro:
      "This section is ready for real clinical cases. For now it uses clear placeholders, so images can be selected and replaced without changing the layout.",
    before: "Before",
    after: "After",
    beforeTitle: "Pre-treatment image missing",
    afterTitle: "Post-treatment image missing",
    beforeDescription:
      "Use only an approved photo of the same case, with consistent angle and light.",
    afterDescription:
      "Use only an approved photo of the same case and the same framing.",
    treatment: "Treatment",
    note: "Do not publish clinical photos until consent, final selection, and verified description are available.",
  },
} as const;

const c = copy[locale];
---

<section id="before-after" class="content-band mt-6">
  <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
    <div class="section-copy">
      <p class="eyebrow">{c.eyebrow}</p>
      <h2 class="section-title mt-4">{c.title}</h2>
      <p class="mt-4 text-sm leading-7 text-ink-soft">{c.intro}</p>
      <p
        class="mt-5 rounded-[var(--radius-clinic)] border border-border bg-canvas-soft/70 p-4 text-sm leading-7 text-ink-soft"
      >
        {c.note}
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <PhotoPlaceholder
        eyebrow={c.before}
        title={c.beforeTitle}
        description={c.beforeDescription}
        aspect="aspect-[3/4]"
      />
      <PhotoPlaceholder
        eyebrow={c.after}
        title={c.afterTitle}
        description={c.afterDescription}
        aspect="aspect-[3/4]"
      />
      <div
        class="md:col-span-2 rounded-[var(--radius-clinic)] border border-border bg-white/82 p-5"
      >
        <p class="eyebrow">{c.treatment}</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          {
            locale === "it"
              ? "Esempio: estetica dentale, igiene professionale, implantologia o ortodonzia. Inserire solo informazioni cliniche confermate."
              : "Example: dental aesthetics, professional hygiene, implantology, or orthodontics. Add only verified clinical information."
          }
        </p>
      </div>
    </div>
  </div>
</section>
