---
type Props = {
  href?: string;
  class?: string;
  compact?: boolean;
};

const {
  href = '/',
  class: className = '',
  compact = false,
} = Astro.props as Props;
---

<a href={href} class:list={['brand-lockup', className]}>
  <img
    src="/brand/regola-d-arte-logo.svg"
    alt="Regola D'arte"
    class="brand-lockup__logo"
    loading="eager"
    decoding="async"
  />
  <span class="brand-lockup__copy">
    <span class="brand-lockup__name">Regola D'arte</span>
    {!compact && <span class="brand-lockup__tagline">Studio dentistico</span>}
  </span>
</a>
