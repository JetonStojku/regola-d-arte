---
type Props = {
  href?: string;
  class?: string;
  compact?: boolean;
  label?: string;
  tagline?: string;
  variant?: 'default' | 'inverse';
};

const {
  href = '/',
  class: className = '',
  compact = false,
  label = "Regola D'arte",
  tagline = 'Studio dentistico',
  variant = 'default',
} = Astro.props as Props;
---

<a href={href} class:list={['brand-lockup', className]}>
  <img
    src={variant === 'inverse' ? '/brand/regola-d-arte-logo-light.svg' : '/brand/regola-d-arte-logo.svg'}
    alt=""
    aria-hidden="true"
    class="brand-lockup__logo"
    loading="eager"
    decoding="async"
  />
  <span class="brand-lockup__copy">
    <span class="brand-lockup__name">{label}</span>
    {!compact && <span class="brand-lockup__tagline">{tagline}</span>}
  </span>
</a>
