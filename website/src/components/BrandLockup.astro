---
import { Image } from "astro:assets";

type Props = {
  href?: string;
  class?: string;
  compact?: boolean;
  label?: string;
  tagline?: string;
  variant?: "default" | "inverse";
  loading?: "eager" | "lazy";
};

const {
  href = "/",
  class: className = "",
  compact = false,
  label = "Studio dentistico Regola d'Arte",
  tagline = "Studio dentistico",
  variant = "default",
  loading = "lazy",
} = Astro.props as Props;
---

<a href={href} class:list={["brand-lockup", className]}>
  <Image
    src={variant === "inverse"
      ? "/brand/regola-d-arte-logo-light.svg"
      : "/brand/regola-d-arte-logo.svg"}
    alt=""
    aria-hidden="true"
    class="brand-lockup__logo"
    width={1500}
    height={1263}
    loading={loading}
    decoding="async"
  />
  <span class="brand-lockup__copy">
    <span class="brand-lockup__name">{label}</span>
    {!compact && <span class="brand-lockup__tagline">{tagline}</span>}
  </span>
</a>
