---
import { contactPageContent } from '@/content/pages';
import Icon from '@/components/ui/Icon.astro';

type Locale = 'it' | 'en';

type Props = {
  locale: Locale;
  variant?: 'rail' | 'mobile' | 'footer' | 'inline';
};

const { locale, variant = 'inline' } = Astro.props as Props;
const contact = contactPageContent[locale];
const actions = [
  {
    label: contact.facebookListingLabel,
    icon: 'simple-icons:facebook',
    href: contact.facebookPageHref,
    external: true,
  },
  {
    label: contact.whatsappLabel,
    icon: 'simple-icons:whatsapp',
    href: contact.whatsappHref,
    external: true,
  },
  {
    label: contact.phoneLabel,
    icon: 'lucide:phone',
    href: contact.phoneHref,
    external: false,
  },
  {
    label: contact.mapListingLabel,
    icon: 'simple-icons:googlemaps',
    href: contact.mapListingHref,
    external: true,
  },
  {
    label: contact.instagramLabel,
    icon: 'simple-icons:instagram',
    href: contact.instagramHref,
    external: true,
  },
].filter((action) => action.href);

const classMap = {
  rail: 'social-links social-links--rail',
  mobile: 'social-links social-links--mobile',
  footer: 'social-links social-links--footer',
  inline: 'social-links social-links--inline',
} as const;

---

<nav class={classMap[variant]} aria-label={locale === 'it' ? 'Link social e contatti rapidi' : 'Social and quick contact links'}>
  <ul>
    {actions.map((action) => (
      <li>
        <a
          href={action.href}
          aria-label={action.label}
          title={action.label}
          target={action.external ? '_blank' : undefined}
          rel={action.external ? 'noreferrer' : undefined}
        >
          <Icon icon={action.icon} class="h-[1.05rem] w-[1.05rem]" />
        </a>
      </li>
    ))}
  </ul>
</nav>
