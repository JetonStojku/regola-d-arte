---
import Icon from '@/components/ui/Icon.astro';

type FeatureItem = {
  eyebrow?: string;
  title: string;
  description: string;
  icon?: string;
  note?: string;
};

type Props = {
  eyebrow?: string;
  title: string;
  intro?: string;
  items: readonly FeatureItem[];
  columns?: 2 | 3;
  class?: string;
};

const {
  eyebrow,
  title,
  intro,
  items,
  columns = 3,
  class: className = '',
} = Astro.props as Props;
---

<section class:list={['content-band mt-6', className]}>
  <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr]">
    <div class="section-copy">
      {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
      <h2 class:list={['section-title', eyebrow && 'mt-4']}>{title}</h2>
      {intro ? <p class="mt-4 text-sm leading-7 text-ink-soft">{intro}</p> : null}
    </div>

    <div class:list={['grid gap-4', columns === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3']}>
      {items.map((item, index) => (
        <div class="feature-tile">
          <div class="feature-tile__number">
            {item.icon ? <Icon icon={item.icon} class="h-4 w-4" /> : index + 1}
          </div>
          <div class="min-w-0">
            {item.eyebrow ? <p class="eyebrow">{item.eyebrow}</p> : null}
            <p class="text-lg font-semibold text-ink">{item.title}</p>
            <p class:list={['text-sm leading-7 text-ink-soft', item.eyebrow ? 'mt-2' : 'mt-3']}>
              {item.description}
            </p>
            {item.note ? <p class="mt-3 text-xs leading-6 text-ink-soft">{item.note}</p> : null}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
