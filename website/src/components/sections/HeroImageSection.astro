---
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import PhotoPlaceholder from '@/components/PhotoPlaceholder.astro';
import ResponsiveImage from '@/components/ui/ResponsiveImage.astro';

type CtaLink = {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
};

type ImageAsset = {
  src: string;
  alt: string;
  width: number;
  height: number;
  sizes: string;
  widths: number[];
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'auto' | 'sync';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
};

type SupportingImage = ImageAsset;

type PlaceholderTile = {
  eyebrow: string;
  title: string;
  description: string;
  aspect?: string;
};

type Props = {
  eyebrow?: string;
  title: string;
  intro: string;
  note?: string;
  primaryCta?: CtaLink;
  secondaryCta?: CtaLink;
  image: ImageAsset;
  supportingImages?: SupportingImage[];
  supportingPlaceholders?: PlaceholderTile[];
  variant?: 'standard' | 'hero';
  class?: string;
};

const {
  eyebrow,
  title,
  intro,
  note,
  primaryCta,
  secondaryCta,
  image,
  supportingImages = [],
  supportingPlaceholders = [],
  variant = 'standard',
  class: className = '',
} = Astro.props as Props;

const isHero = variant === 'hero';
const avatarSources = supportingImages.slice(0, 3);
---

<section class:list={[isHero ? 'full-width-band' : 'content-band', className]}>
  {isHero ? (
    <div class="relative isolate overflow-hidden bg-[#101716] text-white">
      <div class="absolute inset-0">
        <ResponsiveImage
          src={image.src}
          alt={image.alt}
          class={image.class ?? 'h-full w-full object-cover object-center scale-[1.03]'}
          width={image.width}
          height={image.height}
          sizes={image.sizes}
          widths={image.widths}
          loading={image.loading ?? 'lazy'}
          decoding={image.decoding ?? 'async'}
          fetchpriority={image.fetchpriority}
        />
      </div>

      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,14,12,0.56),rgba(10,14,12,0.74)),linear-gradient(135deg,rgba(17,33,66,0.34),transparent_42%),linear-gradient(315deg,rgba(199,161,93,0.18),transparent_38%)]"
      />

      <div class="relative mx-auto flex min-h-[39rem] w-full max-w-[92rem] flex-col px-4 py-8 sm:px-6 sm:py-10 lg:min-h-[47rem] lg:px-8 lg:py-12">
        <div class="flex flex-1 items-center justify-center">
          <div class="max-w-5xl text-center">
            {eyebrow ? (
              <Badge tone="neutral" class="border-white/20 bg-white/92 text-ink shadow-[0_18px_40px_-30px_rgba(17,23,20,0.45)]">
                {eyebrow}
              </Badge>
            ) : null}
            <h1 class="mt-6 text-balance text-4xl font-semibold tracking-[-0.055em] text-white sm:text-5xl lg:text-[5.35rem] lg:leading-[0.95]">
              {title}
            </h1>
          </div>
        </div>

        <div class="mt-6 border-t border-white/15 pt-6 sm:mt-8 sm:pt-7">
          <div class="flex justify-center">
            {primaryCta ? (
              <Button
                href={primaryCta.href}
                variant={primaryCta.variant ?? 'primary'}
                class="rounded-xl !border-[#2f64ff] !bg-[#2f64ff] !px-6 !py-4 !text-base !shadow-[0_18px_36px_-20px_rgba(47,100,255,0.72)] hover:!bg-[#2458eb]"
              >
                <span class="inline-flex items-center gap-2">
                  <span>{primaryCta.label}</span>
                  <span aria-hidden="true">↗</span>
                </span>
              </Button>
            ) : null}
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class:list={[
      'grid gap-8 lg:items-center',
      'lg:grid-cols-[0.94fr_1.06fr]',
    ]}>
      <div class="section-copy">
        {eyebrow ? <Badge tone="accent">{eyebrow}</Badge> : null}
        <h1 class:list={['display-title mt-5 max-w-2xl', eyebrow && 'mt-5']}>{title}</h1>
        <p class="lead mt-4 max-w-2xl">{intro}</p>
        {note ? <p class="mt-4 max-w-xl text-sm leading-7 text-ink-soft">{note}</p> : null}

        {(primaryCta || secondaryCta) ? (
          <div class="mt-8 flex flex-wrap gap-3">
            {primaryCta ? (
              <Button href={primaryCta.href} variant={primaryCta.variant ?? 'primary'}>
                {primaryCta.label}
              </Button>
            ) : null}
            {secondaryCta ? (
              <Button href={secondaryCta.href} variant={secondaryCta.variant ?? 'secondary'}>
                {secondaryCta.label}
              </Button>
            ) : null}
          </div>
        ) : null}
      </div>

      <div class:list={['grid gap-4', 'sm:grid-cols-[1.1fr_0.9fr]']}>
        <div class="visual-frame sm:col-span-2">
          <ResponsiveImage
            src={image.src}
            alt={image.alt}
            class={image.class ?? 'h-[22rem] w-full object-cover object-center'}
            width={image.width}
            height={image.height}
            sizes={image.sizes}
            widths={image.widths}
            loading={image.loading ?? 'lazy'}
            decoding={image.decoding ?? 'async'}
            fetchpriority={image.fetchpriority}
          />
        </div>

        {supportingImages.length > 0
          ? supportingImages.map((supportingImage) => (
              <div class="visual-frame">
                <ResponsiveImage
                  src={supportingImage.src}
                  alt={supportingImage.alt}
                  class={supportingImage.class ?? 'h-44 w-full object-cover object-center'}
                  width={supportingImage.width}
                  height={supportingImage.height}
                  sizes={supportingImage.sizes}
                  widths={supportingImage.widths}
                  loading={supportingImage.loading ?? 'lazy'}
                  decoding={supportingImage.decoding ?? 'async'}
                  fetchpriority={supportingImage.fetchpriority}
                />
              </div>
            ))
          : supportingPlaceholders.map((placeholder) => (
              <PhotoPlaceholder
                eyebrow={placeholder.eyebrow}
                title={placeholder.title}
                description={placeholder.description}
                aspect={placeholder.aspect}
              />
            ))}
      </div>
    </div>
  )}
</section>
