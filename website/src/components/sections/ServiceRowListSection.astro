---
import Icon from '@/components/ui/Icon.astro';

type ServiceRow = {
  label: string;
  summary: string;
  details?: string;
  href: string;
};

type Props = {
  eyebrow?: string;
  title: string;
  intro?: string;
  services: ServiceRow[];
  class?: string;
};

const {
  eyebrow,
  title,
  intro,
  services,
  class: className = '',
} = Astro.props as Props;
---

<section class:list={['content-band mt-6', className]}>
  <div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr]">
    <div class="section-copy">
      {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
      <h2 class:list={['section-title', eyebrow && 'mt-4']}>{title}</h2>
      {intro ? <p class="mt-4 text-sm leading-7 text-ink-soft">{intro}</p> : null}
    </div>

    <div class="rounded-[var(--radius-clinic)] border border-border-strong bg-white/80">
      {services.map((service) => (
        <a href={service.href} class="service-row group px-4 py-4 no-underline sm:px-5" aria-label={service.label}>
          <div class="min-w-0 max-w-3xl">
            <p class="text-lg font-semibold text-ink transition group-hover:text-clinic-900">{service.label}</p>
            <p class="mt-2 text-sm leading-7 text-ink-soft">{service.summary}</p>
            {service.details ? <p class="mt-3 text-sm leading-7 text-ink-soft">{service.details}</p> : null}
          </div>
          <Icon icon="lucide:arrow-up-right" class="mt-1 h-4 w-4 text-clinic-700" />
        </a>
      ))}
    </div>
  </div>
</section>
