---
import Icon from "@/components/ui/Icon.astro";
import ResponsiveImage from "@/components/ui/ResponsiveImage.astro";
import type { Locale } from "@/lib/siteArchitecture";

const serviceImageSizing = {
  "/services-photos/Odontoiatria conservativa ed endodonzia.png": {
    width: 1152,
    height: 768,
    widths: [576, 864, 1152],
  },
  "/services-photos/Chirurgia orale e implantologia.png": {
    width: 1152,
    height: 768,
    widths: [576, 864, 1152],
  },
  "/services-photos/Ortodonzia.png": {
    width: 1152,
    height: 768,
    widths: [576, 864, 1152],
  },
  "/services-photos/Estetica dentale.png": {
    width: 1152,
    height: 768,
    widths: [576, 864, 1152],
  },
  "/services-photos/Igiene orale e prevenzione.png": {
    width: 1152,
    height: 768,
    widths: [576, 864, 1152],
  },
} as const;

type ServiceRow = {
  key: string;
  label: string;
  summary: string;
  details?: string;
  image: {
    src: string;
    alt: Record<Locale, string>;
  };
  href: string;
};

type Props = {
  locale: Locale;
  eyebrow?: string;
  title: string;
  intro?: string;
  note?: string;
  services: ServiceRow[];
  class?: string;
};

const {
  locale,
  eyebrow,
  title,
  intro,
  note,
  services,
  class: className = "",
} = Astro.props as Props;

const getServiceImageSizing = (src: string) =>
  serviceImageSizing[src as keyof typeof serviceImageSizing] ??
  serviceImageSizing[
    "/services-photos/Odontoiatria conservativa ed endodonzia.png"
  ];
---

<section class:list={["content-band mt-6", className]}>
  <div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
    <div class="section-copy" data-reveal>
      {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
      <h2 class:list={["section-title", eyebrow && "mt-4"]}>{title}</h2>
      {
        intro ? (
          <p class="mt-4 text-sm leading-7 text-ink-soft">{intro}</p>
        ) : null
      }
      {
        note ? (
          <p class="mt-4 text-xs font-semibold uppercase tracking-[0.24em] text-ink-soft">
            {note}
          </p>
        ) : null
      }
    </div>

    <div
      class="service-list-panel rounded-[var(--radius-clinic-lg)] border border-border-strong bg-white/82 shadow-[var(--shadow-clinic-soft)]"
    >
      <ol class="service-list">
        {
          services.map((service, index) => {
            const number = String(index + 1).padStart(2, "0");
            const titleId = `service-${service.key}-${index}-title`;
            const summaryId = `service-${service.key}-${index}-summary`;
            const detailsId = `service-${service.key}-${index}-details`;
            const describedBy = service.details
              ? `${summaryId} ${detailsId}`
              : summaryId;
            const imageSizing = getServiceImageSizing(service.image.src);

            return (
              <li
                class="service-list__item"
                data-reveal
                data-reveal-delay={index * 70}
              >
                <a
                  href={service.href}
                  class="service-row hover-restrained group no-underline"
                  aria-labelledby={titleId}
                  aria-describedby={describedBy}
                >
                  <span class="service-row__number" aria-hidden="true">
                    {number}
                  </span>

                  <div class="service-row__copy">
                    <h3 id={titleId} class="service-row__title">
                      {service.label}
                    </h3>
                    <p id={summaryId} class="service-row__summary">
                      {service.summary}
                    </p>
                    {service.details ? (
                      <p id={detailsId} class="service-row__details">
                        {service.details}
                      </p>
                    ) : null}
                  </div>

                  <div class="service-row__media" aria-hidden="true">
                    <ResponsiveImage
                      src={service.image.src}
                      alt={service.image.alt[locale]}
                      width={imageSizing.width}
                      height={imageSizing.height}
                      sizes="(min-width: 1024px) 10rem, 100vw"
                      widths={Array.from(imageSizing.widths)}
                      class="h-full w-full object-cover object-center"
                    />
                  </div>

                  <span class="service-row__arrow" aria-hidden="true">
                    <Icon icon="lucide:arrow-up-right" class="h-4 w-4" />
                  </span>
                </a>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>
