---
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import PhotoPlaceholder from "@/components/PhotoPlaceholder.astro";
import ResponsiveImage from "@/components/ui/ResponsiveImage.astro";

type CtaLink = {
  label: string;
  href: string;
  variant?: "primary" | "secondary" | "ghost";
};

type ImageAsset = {
  src: string;
  alt: string;
  width: number;
  height: number;
  sizes: string;
  widths: number[];
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
};

type SupportingImage = ImageAsset;

type PlaceholderTile = {
  eyebrow: string;
  title: string;
  description: string;
  aspect?: string;
};

type Props = {
  eyebrow?: string;
  title: string;
  intro: string;
  body?: string;
  note?: string;
  primaryCta?: CtaLink;
  secondaryCta?: CtaLink;
  image: ImageAsset;
  supportingImages?: SupportingImage[];
  supportingPlaceholders?: PlaceholderTile[];
  reverse?: boolean;
  titleTag?: "h1" | "h2";
  titleClass?: string;
  class?: string;
};

const {
  eyebrow,
  title,
  intro,
  body,
  note,
  primaryCta,
  secondaryCta,
  image,
  supportingImages = [],
  supportingPlaceholders = [],
  reverse = false,
  titleTag = "h2",
  titleClass = "section-title",
  class: className = "",
} = Astro.props as Props;

const Tag = titleTag;
---

<section class:list={["content-band mt-6", className]}>
  <div
    class:list={[
      "grid gap-8 lg:items-start",
      reverse ? "lg:grid-cols-[1.1fr_0.9fr]" : "lg:grid-cols-[0.92fr_1.08fr]",
    ]}
  >
    <div class:list={["section-copy", reverse && "lg:order-2"]}>
      {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
      <Tag class:list={[titleClass, eyebrow && "mt-4"]}>{title}</Tag>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-ink-soft">{intro}</p>
      {
        body ? (
          <p class="mt-4 max-w-2xl text-sm leading-7 text-ink-soft">{body}</p>
        ) : null
      }
      {
        note ? (
          <p class="mt-4 max-w-2xl text-xs leading-6 text-ink-soft">{note}</p>
        ) : null
      }
      {
        primaryCta || secondaryCta ? (
          <div class="mt-8 flex flex-wrap gap-3">
            {primaryCta ? (
              <Button
                href={primaryCta.href}
                variant={primaryCta.variant ?? "primary"}
              >
                {primaryCta.label}
              </Button>
            ) : null}
            {secondaryCta ? (
              <Button
                href={secondaryCta.href}
                variant={secondaryCta.variant ?? "secondary"}
              >
                {secondaryCta.label}
              </Button>
            ) : null}
          </div>
        ) : null
      }
    </div>

    <div
      class:list={[
        "grid gap-4 sm:grid-cols-[1.1fr_0.9fr]",
        reverse && "lg:order-1",
      ]}
    >
      <div class="visual-frame sm:col-span-2">
        <ResponsiveImage
          src={image.src}
          alt={image.alt}
          class={image.class ?? "h-[22rem] w-full object-cover object-center"}
          width={image.width}
          height={image.height}
          sizes={image.sizes}
          widths={image.widths}
          loading={image.loading ?? "lazy"}
          decoding={image.decoding ?? "async"}
          fetchpriority={image.fetchpriority}
        />
      </div>

      {
        supportingImages.length > 0
          ? supportingImages.map((supportingImage) => (
              <div class="visual-frame">
                <ResponsiveImage
                  src={supportingImage.src}
                  alt={supportingImage.alt}
                  class={
                    supportingImage.class ??
                    "h-44 w-full object-cover object-center"
                  }
                  width={supportingImage.width}
                  height={supportingImage.height}
                  sizes={supportingImage.sizes}
                  widths={supportingImage.widths}
                  loading={supportingImage.loading ?? "lazy"}
                  decoding={supportingImage.decoding ?? "async"}
                  fetchpriority={supportingImage.fetchpriority}
                />
              </div>
            ))
          : supportingPlaceholders.map((placeholder) => (
              <PhotoPlaceholder
                eyebrow={placeholder.eyebrow}
                title={placeholder.title}
                description={placeholder.description}
                aspect={placeholder.aspect}
              />
            ))
      }
    </div>
  </div>
</section>
