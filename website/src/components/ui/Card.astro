---
type Props = {
  as?: 'div' | 'section' | 'article';
  href?: string;
  tone?: 'default' | 'muted';
  class?: string;
};

const {
  as = 'div',
  href,
  tone = 'default',
  class: className = '',
} = Astro.props as Props;

const Tag = as;
const toneClassMap = {
  default: 'card',
  muted: 'card-muted',
} as const;
---

{href ? (
  <a href={href} class:list={[toneClassMap[tone], className]}>
    <slot />
  </a>
) : (
  <Tag class:list={[toneClassMap[tone], className]}>
    <slot />
  </Tag>
)}
