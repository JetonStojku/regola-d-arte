---
import { Image } from "astro:assets";

type Props = {
  src: string;
  alt: string;
  width: number;
  height: number;
  sizes: string;
  widths: number[];
  class?: string;
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
};

const {
  src,
  alt,
  width,
  height,
  sizes,
  widths,
  class: className = "",
  loading = "lazy",
  decoding = "async",
  fetchpriority,
} = Astro.props as Props;

const match = src.match(/^(.*)(\.[^.]+)$/);
const baseName = match?.[1] ?? src;
const extension = match?.[2] ?? "";
const srcSet = widths
  .slice()
  .sort((a, b) => a - b)
  .map((candidateWidth) => {
    const candidateSrc =
      candidateWidth === width
        ? src
        : `${baseName}-${candidateWidth}${extension}`;
    return `${candidateSrc} ${candidateWidth}w`;
  })
  .join(", ");
---

<Image
  src={src}
  srcset={srcSet}
  sizes={sizes}
  width={width}
  height={height}
  alt={alt}
  class={className}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchpriority}
/>
