---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  robots?: string;
};

const {
  title = 'Regola D\'arte',
  description = 'Regola D\'arte clinic website scaffold.',
  robots,
} = Astro.props as Props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
  </head>
  <body>
    <slot />
  </body>
</html>
