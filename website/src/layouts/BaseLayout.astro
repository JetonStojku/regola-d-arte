---
import '../styles/global.css';
import BrandLockup from '@/components/BrandLockup.astro';
import type { Locale } from '@/lib/siteArchitecture';
import { sectionRoutes } from '@/lib/siteArchitecture';

type Props = {
  title?: string;
  description?: string;
  robots?: string;
  locale?: Locale;
  canonical?: string;
  alternateLinks?: Array<{
    locale: Locale;
    href: string;
  }>;
};

const {
  title = 'Regola D\'arte',
  description = 'Regola D\'arte clinic website scaffold.',
  robots,
  locale = 'it',
  canonical,
  alternateLinks = [],
} = Astro.props as Props;
---

<!doctype html>
<html lang={locale} data-locale={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f3ed" />
    {canonical && <link rel="canonical" href={canonical} />}
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.locale} href={link.href} />
    ))}
    {robots && <meta name="robots" content={robots} />}
  </head>
  <body>
    <a class="skip-link" href="#content">
      {locale === 'it' ? 'Vai al contenuto principale' : 'Skip to content'}
    </a>
    <header class="page-shell pt-4 sm:pt-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <BrandLockup href={sectionRoutes.home[locale]} compact class="max-w-[18rem]" />
        {alternateLinks.length > 0 && (
          <nav aria-label={locale === 'it' ? 'Selettore lingua' : 'Language selector'}>
            <div class="flex flex-wrap justify-start gap-2 sm:justify-end">
              {alternateLinks.map((link) => (
                <a
                  href={link.href}
                  aria-current={link.isCurrent ? 'page' : undefined}
                  class:list={[link.isCurrent ? 'chip--active' : 'chip--quiet', 'chip']}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </nav>
        )}
      </div>
    </header>
    <slot />
  </body>
</html>
