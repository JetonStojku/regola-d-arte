---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { sectionRoutes } from '@/lib/siteArchitecture';
---

<BaseLayout
  title="Regola D'arte | Pagina non trovata"
  description="Pagina 404 statica per il sito Regola D'arte."
  robots="noindex,follow"
>
  <main class="mx-auto flex min-h-screen max-w-3xl items-center px-6 py-16">
    <section class="w-full rounded-3xl border border-slate-200 bg-white p-8">
      <p class="text-sm uppercase tracking-[0.24em] text-slate-500">404</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950">
        Pagina non trovata
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-700">
        La pagina richiesta non fa ancora parte della mappa URL pubblicata. Usa l&apos;esperienza
        italiana principale o la versione inglese per continuare.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={sectionRoutes.home.it}
          class="rounded-full bg-slate-950 px-5 py-3 text-sm font-medium text-white"
        >
          Vai alla home italiana
        </a>
        <a
          href={sectionRoutes.home.en}
          class="rounded-full border border-slate-300 px-5 py-3 text-sm font-medium text-slate-900"
        >
          Vai alla home inglese
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
