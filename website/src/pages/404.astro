---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { commonLabels } from '@/content/common';
import { metaContent, notFoundPageContent } from '@/content/pages';
import { navigationContent } from '@/content/navigation';
import { sectionRoutes } from '@/lib/siteArchitecture';

const locale = 'it' as const;
const content = notFoundPageContent.it;
const metadata = metaContent.notFound.it;
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.notFound.it}
  robots="noindex,follow"
>
  <main class="mx-auto flex min-h-screen max-w-3xl items-center px-6 py-16">
    <section class="w-full rounded-3xl border border-slate-200 bg-white p-8">
      <p class="text-sm uppercase tracking-[0.24em] text-slate-500">{content.eyebrow}</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950">{content.title}</h1>
      <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-700">{content.intro}</p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={sectionRoutes.home.it}
          class="rounded-full bg-slate-950 px-5 py-3 text-sm font-medium text-white"
        >
          {content.primaryButtonLabel}
        </a>
        <a
          href={sectionRoutes.home.en}
          class="rounded-full border border-slate-300 px-5 py-3 text-sm font-medium text-slate-900"
        >
          {content.secondaryButtonLabel}
        </a>
      </div>

      <div class="mt-10 rounded-2xl border border-slate-200 bg-slate-50 p-5">
        <p class="text-sm uppercase tracking-[0.2em] text-slate-500">{commonLabels.primaryNavigation.it}</p>
        <div class="mt-3 flex flex-wrap gap-3 text-sm text-slate-700">
          {navigationContent.primary.it.map((item) => (
            <a class="rounded-full border border-slate-300 bg-white px-4 py-2" href={item.href}>
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
