---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandLockup from '@/components/BrandLockup.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import Section from '@/components/ui/Section.astro';
import TextLink from '@/components/ui/TextLink.astro';
import { sectionRoutes } from '@/lib/siteArchitecture';

const locale = 'it' as const;
---

<BaseLayout
  title="Regola D'arte design system"
  description="Internal style guide for the Regola D'arte website design system."
  locale={locale}
  canonical="/design-system/"
  robots="noindex,follow"
>
  <section class="surface overflow-hidden">
    <div class="grid gap-0 lg:grid-cols-[1.08fr_0.92fr]">
      <div class="p-6 sm:p-8 lg:p-10">
        <BrandLockup class="max-w-xs" />
        <Badge tone="accent" class="mt-6">Visual system</Badge>
        <h1 class="display-title mt-5 max-w-2xl">Premium, calm, clinical, and readable.</h1>
        <p class="lead mt-4 max-w-2xl">
          The system is tuned for dentistry: restrained color, soft surfaces, clear hierarchy,
          and enough warmth to feel human without drifting into decorative clutter.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.home.it}>Primary</Button>
          <Button href={sectionRoutes.home.it} variant="secondary">
            Secondary
          </Button>
          <Button href={sectionRoutes.home.it} variant="ghost">
            Ghost
          </Button>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <Badge tone="neutral">Neutral badge</Badge>
          <Badge tone="accent">Accent badge</Badge>
          <Badge tone="warm">Warm badge</Badge>
        </div>
      </div>

      <aside class="border-t border-border bg-canvas-soft/70 p-6 sm:p-8 lg:border-l lg:border-t-0">
        <div class="grid gap-4">
          <Card class="p-5">
            <p class="eyebrow">Surface</p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">
              Cards use modest radius, a clean border, and a subtle clinic shadow for depth.
            </p>
          </Card>
          <Card tone="muted" class="p-5">
            <p class="eyebrow">Typography</p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">
              Headlines use a serif display face; body copy stays on a neutral sans stack.
            </p>
          </Card>
          <Card class="p-5">
            <p class="eyebrow">Link treatment</p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">
              <TextLink href={sectionRoutes.home.it}>Links stay visible and understated.</TextLink>
            </p>
          </Card>
        </div>
      </aside>
    </div>
  </section>

  <Section
    eyebrow="Spacing"
    title="Responsive rhythm"
    intro="The layout scales from compact mobile stacking to a two-column editorial rhythm on desktop."
  >
    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <Card class="p-5">
        <p class="eyebrow">Canvas</p>
        <div class="mt-4 h-24 rounded-[var(--radius-clinic)] border border-border bg-canvas"></div>
      </Card>
      <Card class="p-5">
        <p class="eyebrow">Surface</p>
        <div class="mt-4 h-24 rounded-[var(--radius-clinic)] border border-border bg-surface"></div>
      </Card>
      <Card class="p-5">
        <p class="eyebrow">Clinic</p>
        <div class="mt-4 h-24 rounded-[var(--radius-clinic)] border border-clinic-100 bg-clinic-50"></div>
      </Card>
      <Card class="p-5">
        <p class="eyebrow">Gold</p>
        <div class="mt-4 h-24 rounded-[var(--radius-clinic)] border border-gold-100 bg-gold-100"></div>
      </Card>
    </div>
  </Section>
</BaseLayout>
