---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureGridSection from '@/components/sections/FeatureGridSection.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import PhotoPlaceholder from '@/components/PhotoPlaceholder.astro';
import ResponsiveImage from '@/components/ui/ResponsiveImage.astro';
import { pageMetadata } from '@/content/metadata';
import { navigationContent } from '@/content/navigation';
import { teamSectionContent } from '@/content/pages';
import { buildClinicSchema } from '@/lib/schema';
import { sectionRoutes } from '@/lib/siteArchitecture';
import { getLanguageSwitcherLinks, getSeoAlternateLinks } from '@/lib/siteArchitecture';

const locale = 'en' as const;
const metadata = pageMetadata.about.en;
const teamContent = teamSectionContent.en;
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.about.en}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.about, locale)}
  alternateLinks={getLanguageSwitcherLinks('about', locale)}
  structuredData={structuredData}
>
  <section class="content-band">
    <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div class="section-copy">
        <Badge tone="accent">About</Badge>
        <h1 class="display-title mt-5 max-w-2xl">Regola D&apos;arte, your smile, our art</h1>
        <p class="lead mt-4 max-w-2xl">
          We believe every smile deserves attention, precision, and beauty. That is why we combine
          clinical expertise, aesthetics, science, and humanity in a personalized care journey.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-ink-soft">
          Our philosophy is built on treatment precision, material quality, and close attention to
          biomechanics, occlusion, and function, so the results are functional, harmonious, and
          durable.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.servicesOverview.en}>{navigationContent.primary.en[1].label}</Button>
          <Button href={sectionRoutes.contact.en} variant="secondary">
            {navigationContent.primary.en[2].label}
          </Button>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="visual-frame sm:col-span-2">
          <ResponsiveImage
            src="/brand/about-doctor.jpg"
            alt="Dr. Genti Dylgjeri in a modern dental surgery"
            class="h-[22rem] w-full object-cover object-center"
            width={1280}
            height={720}
            sizes="(min-width: 1024px) 35rem, 100vw"
            widths={[640, 960, 1280]}
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <div class="visual-frame">
          <ResponsiveImage
            src="/brand/about-clinic.jpg"
            alt="Dental team during a treatment session in a modern clinic"
            class="h-56 w-full object-cover object-center"
            width={800}
            height={533}
            sizes="(min-width: 1024px) 35rem, 100vw"
            widths={[480, 800, 1200]}
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <PhotoPlaceholder
          eyebrow="Clinic photo"
          title="Professional detail"
          description="Add a photo of equipment, room, or a detail that communicates precision."
        />
      </div>
    </div>
  </section>

  <FeatureGridSection
    eyebrow="Key points"
    title="Three concrete signals of our approach."
    intro="The structure of this page summarizes diagnosis, aesthetics, and confirmed services without introducing unverified content."
    items={[
      {
        eyebrow: 'Precision and function',
        title: 'Every plan starts from an accurate diagnosis.',
        description:
          'Treatments are prepared with care and a multidisciplinary mindset, always tailored to the patient&apos;s specific needs.',
      },
      {
        eyebrow: 'Aesthetics and science',
        title: 'Smile design follows solid clinical criteria.',
        description:
          'Aesthetic care is never detached from function: the goal is a result that feels natural, comfortable, and stable over time.',
      },
      {
        eyebrow: 'Confirmed services',
        title: 'From preventive care to more complex treatment plans.',
        description:
          'The practice covers restorative dentistry and endodontics, oral surgery and implantology, orthodontics, dental aesthetics, and professional oral hygiene.',
      },
    ]}
  />

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr]">
      <div class="section-copy">
        <p class="eyebrow">{teamContent.eyebrow}</p>
        <h2 class="section-title mt-4">{teamContent.title}</h2>
        <p class="mt-4 text-sm leading-7 text-ink-soft">{teamContent.intro}</p>
        <p class="mt-4 rounded-2xl border border-border bg-canvas-soft/70 p-4 text-sm leading-7 text-ink-soft">
          {teamContent.fallbackNote}
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {teamContent.members.map((member) => (
          <Card class="overflow-hidden p-0">
            <ResponsiveImage
              src={member.photoSrc}
              alt={member.photoAlt}
              class="h-56 w-full object-cover object-center"
              width={member.photoSrc === '/brand/about-clinic.jpg' ? 800 : 1280}
              height={member.photoSrc === '/brand/about-clinic.jpg' ? 533 : 720}
              sizes="(min-width: 640px) 20rem, 100vw"
              widths={member.photoSrc === '/brand/about-clinic.jpg' ? [480, 800, 1200] : [640, 960, 1280]}
              loading="lazy"
            />
            <div class="p-5">
              <p class="text-lg font-semibold text-ink">{member.name ?? member.role}</p>
              <p class="mt-2 text-xs uppercase tracking-[0.18em] text-ink-soft">{member.role}</p>
              <p class="mt-3 text-sm leading-7 text-ink-soft">{member.summary}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <div class="info-tile mt-6">
      <p class="eyebrow">Missing content</p>
      <p class="mt-3 text-sm leading-7 text-ink-soft">{teamContent.missingNote}</p>
    </div>
  </section>
</BaseLayout>
