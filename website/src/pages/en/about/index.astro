---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import { pageMetadata } from '@/content/metadata';
import { navigationContent } from '@/content/navigation';
import { teamSectionContent } from '@/content/pages';
import { buildClinicSchema } from '@/lib/schema';
import { sectionRoutes } from '@/lib/siteArchitecture';
import { getLanguageSwitcherLinks, getSeoAlternateLinks } from '@/lib/siteArchitecture';

const locale = 'en' as const;
const metadata = pageMetadata.about.en;
const teamContent = teamSectionContent.en;
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.about.en}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.about, locale)}
  alternateLinks={getLanguageSwitcherLinks('about', locale)}
  structuredData={structuredData}
>
  <section class="surface overflow-hidden">
    <div class="grid gap-0 lg:grid-cols-[1.02fr_0.98fr]">
      <div class="p-6 sm:p-8 lg:p-10">
        <Badge tone="accent">About</Badge>
        <h1 class="display-title mt-5 max-w-2xl">Regola D&apos;arte, your smile, our art</h1>
        <p class="lead mt-4 max-w-2xl">
          We believe every smile deserves attention, precision, and beauty. That is why we combine
          clinical expertise, aesthetics, science, and humanity in a personalized care journey.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-ink-soft">
          Our philosophy is built on treatment precision, material quality, and close attention to
          biomechanics, occlusion, and function, so the results are functional, harmonious, and
          durable.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.servicesOverview.en}>{navigationContent.primary.en[1].label}</Button>
          <Button href={sectionRoutes.contact.en} variant="secondary">
            {navigationContent.primary.en[2].label}
          </Button>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          <Card class="p-5">
            <p class="eyebrow">Precision and function</p>
            <p class="mt-3 text-lg font-semibold text-ink">Every plan starts with an accurate diagnosis.</p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">
              Treatments are prepared with care and a multidisciplinary mindset, always tailored to
              the patient&apos;s specific needs.
            </p>
          </Card>
          <Card tone="muted" class="p-5">
            <p class="eyebrow">Aesthetics and science</p>
            <p class="mt-3 text-lg font-semibold text-ink">Smile design follows solid clinical criteria.</p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">
              Aesthetic care is never detached from function: the goal is a result that feels
              natural, comfortable, and stable over time.
            </p>
          </Card>
        </div>
      </div>

      <aside class="border-t border-border bg-canvas-soft/70 p-6 sm:p-8 lg:border-l lg:border-t-0">
        <div class="grid gap-4">
          <Card class="overflow-hidden p-0">
            <img
              src="/brand/about-doctor.jpg"
              alt="Portrait of the Regola D&apos;arte clinician"
              class="h-72 w-full object-cover object-center"
              loading="eager"
            />
          </Card>

          <Card class="overflow-hidden p-0">
            <img
              src="/brand/about-clinic.jpg"
              alt="Inside the Regola D&apos;arte dental clinic"
              class="h-56 w-full object-cover object-center"
              loading="eager"
            />
          </Card>

          <Card class="p-5">
            <p class="eyebrow">Our method</p>
            <p class="mt-3 text-lg font-semibold text-ink">Personalized care for prevention, aesthetics, and function.</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-ink-soft">
              <li>• Treatment precision and quality materials</li>
              <li>• Attention to biomechanics, occlusion, and function</li>
              <li>• Functional, durable, and harmonious outcomes</li>
            </ul>
          </Card>
        </div>
      </aside>
    </div>
  </section>

  <section class="surface mt-6 p-6 sm:p-8 lg:p-10">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <Card class="p-5">
        <p class="eyebrow">Confirmed services</p>
        <p class="mt-3 text-lg font-semibold text-ink">From preventive care to more complex treatment plans.</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          The practice covers restorative dentistry and endodontics, oral surgery and implantology,
          orthodontics, dental aesthetics, and professional oral hygiene.
        </p>
      </Card>

      <Card tone="muted" class="p-5">
        <p class="eyebrow">Next step</p>
        <p class="mt-3 text-lg font-semibold text-ink">Explore treatments or contact us for an initial consultation.</p>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-ink-soft">
          Every treatment is planned clearly, based on the specific needs of each patient.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={sectionRoutes.servicesOverview.en}>{navigationContent.primary.en[1].label}</Button>
          <Button href={sectionRoutes.contact.en} variant="secondary">
            {navigationContent.primary.en[2].label}
          </Button>
        </div>
      </Card>
    </div>
  </section>

  <section class="surface mt-6 p-6 sm:p-8 lg:p-10">
    <div class="grid gap-6 lg:grid-cols-[0.84fr_1.16fr]">
      <Card class="p-5">
        <p class="eyebrow">{teamContent.eyebrow}</p>
        <h2 class="section-title mt-4">{teamContent.title}</h2>
        <p class="mt-4 text-sm leading-7 text-ink-soft">{teamContent.intro}</p>
        <p class="mt-4 rounded-2xl border border-border bg-canvas-soft/70 p-4 text-sm leading-7 text-ink-soft">
          {teamContent.fallbackNote}
        </p>
      </Card>

      <div class="grid gap-4 sm:grid-cols-2">
        {teamContent.members.map((member) => (
          <Card class="overflow-hidden p-0">
            <img
              src={member.photoSrc}
              alt={member.photoAlt}
              class="h-56 w-full object-cover object-center"
              loading="lazy"
            />
            <div class="p-5">
              <p class="text-lg font-semibold text-ink">{member.name ?? member.role}</p>
              <p class="mt-2 text-xs uppercase tracking-[0.18em] text-ink-soft">{member.role}</p>
              <p class="mt-3 text-sm leading-7 text-ink-soft">{member.summary}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <Card tone="muted" class="mt-6 p-5">
      <p class="eyebrow">Missing content</p>
      <p class="mt-3 text-sm leading-7 text-ink-soft">{teamContent.missingNote}</p>
    </Card>
  </section>
</BaseLayout>
