---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import { commonLabels } from '@/content/common';
import { homePageContent, metaContent } from '@/content/pages';
import { navigationContent } from '@/content/navigation';
import {
  getLanguageSwitcherLinks,
  sectionRoutes,
} from '@/lib/siteArchitecture';

const locale = 'en' as const;
const content = homePageContent.en;
const metadata = metaContent.home.en;
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.home.en}
  alternateLinks={getLanguageSwitcherLinks('home', locale)}
  robots="noindex,follow"
>
  <main id="content" class="page-shell section-shell">
    <section class="surface overflow-hidden">
      <div class="grid gap-0 lg:grid-cols-[1.02fr_0.98fr]">
        <div class="p-6 sm:p-8 lg:p-10">
          <Badge tone="accent">{content.eyebrow}</Badge>
          <h1 class="display-title mt-5 max-w-xl">{content.title}</h1>
          <p class="lead mt-4 max-w-2xl">{content.intro}</p>

          <div class="mt-8 flex flex-wrap gap-3">
            {navigationContent.primary.en.map((item) => (
              <Button href={item.href} variant="secondary" size="sm">
                {item.label}
              </Button>
            ))}
          </div>

          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            <Card class="p-5">
              <p class="eyebrow">{commonLabels.languageSwitcher.en}</p>
              <p class="mt-3 text-lg font-semibold text-ink">{content.routeLabel}</p>
              <p class="mt-2 text-sm text-ink-soft">{sectionRoutes.home.en}</p>
            </Card>
            <Card tone="muted" class="p-5">
              <p class="eyebrow">{content.navigationTitle}</p>
              <p class="mt-3 text-lg font-semibold text-ink">{commonLabels.primaryNavigation.en}</p>
              <p class="mt-2 text-sm text-ink-soft">{content.homePathLabel}</p>
            </Card>
          </div>
        </div>

        <aside class="border-t border-border bg-canvas-soft/70 p-6 sm:p-8 lg:border-l lg:border-t-0">
          <Card class="p-5">
            <p class="eyebrow">Quick index</p>
            <div class="mt-4 space-y-3 text-sm text-ink-soft">
              {navigationContent.footer.en.map((item) => (
                <p>
                  <span class="font-semibold text-ink">{item.label}</span> · {item.href}
                </p>
              ))}
            </div>
          </Card>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>
