---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BeforeAfterSection from '@/components/BeforeAfterSection.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import PhotoPlaceholder from '@/components/PhotoPlaceholder.astro';
import ResponsiveImage from '@/components/ui/ResponsiveImage.astro';
import { homePageContent, metaContent } from '@/content/pages';
import { navigationContent } from '@/content/navigation';
import { getLocalizedServices } from '@/content/services';
import { buildClinicSchema } from '@/lib/schema';
import {
  getLanguageSwitcherLinks,
  getSeoAlternateLinks,
  sectionRoutes,
} from '@/lib/siteArchitecture';

const locale = 'en' as const;
const content = homePageContent.en;
const metadata = metaContent.home.en;
const services = getLocalizedServices(locale).slice(0, 3);
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.home.en}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.home, locale)}
  alternateLinks={getLanguageSwitcherLinks('home', locale)}
  structuredData={structuredData}
>
  <section class="content-band">
    <div class="grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-center">
      <div class="section-copy">
        <Badge tone="accent">{content.eyebrow}</Badge>
        <h1 class="display-title mt-5 max-w-2xl">{content.title}</h1>
        <p class="lead mt-4 max-w-2xl">{content.intro}</p>
        <p class="mt-4 max-w-xl text-sm leading-7 text-ink-soft">{content.heroNote}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.servicesOverview.en}>{content.heroPrimaryCta}</Button>
          <Button href={sectionRoutes.contact.en} variant="secondary">
            {content.heroSecondaryCta}
          </Button>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-[1.1fr_0.9fr]">
        <div class="visual-frame sm:col-span-2">
            <ResponsiveImage
              src="/brand/homepage-hero.jpg"
              alt="Dr. Genti Dylgjeri in a modern dental surgery"
              class="h-[22rem] w-full object-cover object-center"
              width={1280}
              height={720}
              sizes="(min-width: 1024px) 35rem, 100vw"
              widths={[640, 960, 1280]}
              loading="eager"
              fetchpriority="high"
            />
        </div>
        <PhotoPlaceholder
          eyebrow="Clinic photo"
          title="Interior detail"
          description="Add a bright photo of reception, surgery room, or a clinic detail."
        />
        <PhotoPlaceholder
          eyebrow="Team photo"
          title="Welcome moment"
          description="Add an approved photo of the team or patient welcome experience."
        />
      </div>
    </div>
  </section>

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div class="section-copy">
        <p class="eyebrow">{content.servicesEyebrow}</p>
        <h2 class="section-title mt-4">{content.servicesTitle}</h2>
        <p class="mt-4 text-sm leading-7 text-ink-soft">{content.servicesIntro}</p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {services.map((service) => (
          <Card href={service.href} as="article" class="overflow-hidden p-0 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-clinic)]">
            <PhotoPlaceholder
              eyebrow="Service image"
              title={service.label}
              description="Replace with a photo matching this treatment."
              aspect="aspect-[4/3]"
              class="rounded-b-none border-x-0 border-t-0"
            />
            <div class="p-5">
              <p class="text-lg font-semibold text-ink">{service.label}</p>
              <p class="mt-3 text-sm leading-7 text-ink-soft">{service.summary}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <BeforeAfterSection locale={locale} />

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="info-tile">
        <p class="eyebrow">{content.storyEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.storyTitle}</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">{content.storyBody}</p>
      </div>
      <div class="info-tile">
        <p class="eyebrow">{content.trustEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.trustTitle}</p>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-ink-soft">
          {content.trustPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>
      <div class="info-tile">
        <p class="eyebrow">{content.contactEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.contactTitle}</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">{content.contactIntro}</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={sectionRoutes.contact.en}>{navigationContent.primary.en[2].label}</Button>
          <Button href={sectionRoutes.servicesOverview.en} variant="secondary">
            {navigationContent.primary.en[1].label}
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
