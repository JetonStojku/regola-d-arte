---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import { homePageContent, metaContent } from '@/content/pages';
import { navigationContent } from '@/content/navigation';
import { getLocalizedServices } from '@/content/services';
import { buildClinicSchema } from '@/lib/schema';
import {
  getLanguageSwitcherLinks,
  getSeoAlternateLinks,
  sectionRoutes,
} from '@/lib/siteArchitecture';

const locale = 'en' as const;
const content = homePageContent.en;
const metadata = metaContent.home.en;
const services = getLocalizedServices(locale).slice(0, 3);
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.home.en}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.home, locale)}
  alternateLinks={getLanguageSwitcherLinks('home', locale)}
  structuredData={structuredData}
>
  <section class="surface overflow-hidden">
    <div class="grid gap-0 lg:grid-cols-[1.02fr_0.98fr]">
      <div class="p-6 sm:p-8 lg:p-10">
        <Badge tone="accent">{content.eyebrow}</Badge>
        <h1 class="display-title mt-5 max-w-2xl">{content.title}</h1>
        <p class="lead mt-4 max-w-2xl">{content.intro}</p>
        <p class="mt-4 max-w-xl text-sm leading-7 text-ink-soft">{content.heroNote}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.servicesOverview.en}>{content.heroPrimaryCta}</Button>
          <Button href={sectionRoutes.contact.en} variant="secondary">
            {content.heroSecondaryCta}
          </Button>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          <Card class="p-5">
            <p class="eyebrow">{content.storyEyebrow}</p>
            <p class="mt-3 text-lg font-semibold text-ink">{content.storyTitle}</p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">{content.storyBody}</p>
          </Card>
          <Card tone="muted" class="p-5">
            <p class="eyebrow">{content.trustEyebrow}</p>
            <p class="mt-3 text-lg font-semibold text-ink">{content.trustTitle}</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-ink-soft">
              {content.trustPoints.map((point) => (
                <li>• {point}</li>
              ))}
            </ul>
          </Card>
        </div>
      </div>

      <aside class="border-t border-border bg-canvas-soft/70 p-6 sm:p-8 lg:border-l lg:border-t-0">
        <div class="grid gap-4">
          <Card class="overflow-hidden p-0">
            <img
              src="/brand/homepage-hero.jpg"
              alt="Regola D'arte dental clinic"
              class="h-72 w-full object-cover object-center"
              loading="eager"
            />
          </Card>

          <Card class="p-5">
            <p class="eyebrow">{content.servicesEyebrow}</p>
            <p class="mt-3 text-lg font-semibold text-ink">{content.servicesTitle}</p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">{content.servicesIntro}</p>
            <div class="mt-5 grid gap-3">
              {services.map((service) => (
                <a
                  href={service.href}
                  class="rounded-2xl border border-border bg-white/80 p-4 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-clinic-soft)]"
                >
                  <div class="flex items-center justify-between gap-4">
                    <div>
                      <p class="text-sm font-semibold text-ink">{service.label}</p>
                      <p class="mt-1 text-sm leading-6 text-ink-soft">{service.summary}</p>
                    </div>
                    <span class="text-xs uppercase tracking-[0.18em] text-ink-soft">01</span>
                  </div>
                </a>
              ))}
            </div>
          </Card>
        </div>
      </aside>
    </div>
  </section>

  <section class="surface mt-6 p-6 sm:p-8 lg:p-10">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <Card class="p-5">
        <p class="eyebrow">{content.reviewsEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.reviewsTitle}</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">{content.reviewsIntro}</p>
        <div class="mt-5 rounded-2xl border border-border bg-white/80 p-4">
          <p class="text-sm font-semibold text-ink">{content.reviewsOfficialLabel}</p>
          <a
            href={content.reviewsOfficialHref}
            class="mt-2 inline-flex text-sm font-medium text-brand underline decoration-brand/40 underline-offset-4 transition hover:decoration-brand"
            target="_blank"
            rel="noreferrer"
          >
            {content.reviewsOfficialHref}
          </a>
          <p class="mt-3 text-xs leading-6 text-ink-soft">{content.reviewsOfficialNote}</p>
        </div>
        <p class="mt-4 text-xs leading-6 text-ink-soft">{content.reviewsMissingNote}</p>
      </Card>

      <Card tone="muted" class="p-5">
        <p class="eyebrow">{content.contactEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.contactTitle}</p>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-ink-soft">{content.contactIntro}</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={sectionRoutes.contact.en}>{navigationContent.primary.en[2].label}</Button>
          <Button href={sectionRoutes.servicesOverview.en} variant="secondary">
            {navigationContent.primary.en[1].label}
          </Button>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
