---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import FeatureGridSection from '@/components/sections/FeatureGridSection.astro';
import SplitMediaSection from '@/components/sections/SplitMediaSection.astro';
import { getLocalizedServiceContent, getServiceEntry, getServiceKeyByLocalizedSlug, serviceCatalog } from '@/content/services';
import { serviceMetadata } from '@/content/metadata';
import { buildClinicSchema, buildServiceSchema } from '@/lib/schema';
import { getOtherLocale, getSeoAlternateLinks, sectionRoutes } from '@/lib/siteArchitecture';

const locale = 'en' as const;
const slug = Astro.params.slug ?? '';
const serviceKey = getServiceKeyByLocalizedSlug(slug, locale);

if (!serviceKey) {
  return Astro.redirect(sectionRoutes.servicesOverview.en, 302);
}

const service = getServiceEntry(serviceKey);
const content = getLocalizedServiceContent(serviceKey, locale);
const metadata = serviceMetadata[serviceKey].en;
const heroIsClinicImage = service.images.hero.src === '/brand/about-clinic.jpg';
const heroImageWidth = heroIsClinicImage ? 800 : 1280;
const heroImageHeight = heroIsClinicImage ? 533 : 720;
const heroImageWidths = heroIsClinicImage ? [480, 800, 1200] : [640, 960, 1280];
const localizedAlternates = {
  it: service.paths.it,
  en: service.paths.en,
};
const structuredData = [
  buildClinicSchema(locale, metadata.description, { site: Astro.site }),
  buildServiceSchema(serviceKey, locale, metadata.description, { site: Astro.site }),
];

export function getStaticPaths() {
  return Object.entries(serviceCatalog).map(([, service]) => ({
    params: { slug: service.slugs.en },
  }));
}
---

<BaseLayout
  title={serviceMetadata[serviceKey].en.title}
  description={serviceMetadata[serviceKey].en.description}
  locale={locale}
  canonical={service.paths.en}
  hreflangLinks={getSeoAlternateLinks(localizedAlternates, locale)}
  alternateLinks={[{ locale: getOtherLocale(locale), href: service.paths.it, label: 'Italiano', isCurrent: false }]}
  structuredData={structuredData}
>
  <SplitMediaSection
    eyebrow="Service"
    title={service.labels.en}
    intro={content.summary}
    body={content.details}
    primaryCta={{ label: content.ctas.primary, href: sectionRoutes.contact.en }}
    secondaryCta={{ label: 'Back to services', href: sectionRoutes.servicesOverview.en, variant: 'secondary' }}
    image={{
      src: service.images.hero.src,
      alt: service.images.hero.alt.en,
      class: 'h-[22rem] w-full object-cover object-center',
      width: heroImageWidth,
      height: heroImageHeight,
      sizes: '(min-width: 1024px) 35rem, 100vw',
      widths: heroImageWidths,
      loading: 'eager',
      fetchpriority: 'high',
    }}
    supportingPlaceholders={[
      {
        eyebrow: 'Service detail',
        title: 'Dedicated clinical image',
        description: 'Add an approved photo specific to this treatment.',
      },
      {
        eyebrow: 'Patient journey',
        title: 'Treatment phase',
        description: 'Add a second image or detail to balance the page.',
      },
    ]}
    titleTag="h1"
    titleClass="display-title"
  />

  <FeatureGridSection
    eyebrow="Key content"
    title="The main points of the treatment."
    intro="The grid summarizes the information already present in the local content while keeping the page rhythm consistent."
    items={content.sections.map((section) => ({
      eyebrow: section.eyebrow.en,
      title: section.title.en,
      description: section.body.en,
      note: section.bullets?.en ? section.bullets.en.join(' • ') : undefined,
    }))}
    columns={2}
  />

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="info-tile">
        <p class="eyebrow">Frequently asked questions</p>
        <div class="mt-4 space-y-4">
          {content.faqs.map((faq) => (
            <div>
              <p class="font-semibold text-ink">{faq.question.en}</p>
              <p class="mt-2 text-sm leading-7 text-ink-soft">{faq.answer.en}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="info-tile">
        <p class="eyebrow">{content.ctas.related}</p>
        <p class="mt-3 text-lg font-semibold text-ink">Discover the related services too.</p>
        <div class="mt-5 flex flex-wrap gap-3">
          {content.relatedServices.map((relatedServiceKey) => (
            <Button href={getServiceEntry(relatedServiceKey).paths.en} variant="secondary">
              {getServiceEntry(relatedServiceKey).labels.en}
            </Button>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
