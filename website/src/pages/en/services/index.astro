---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BeforeAfterSection from '@/components/BeforeAfterSection.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import PhotoPlaceholder from '@/components/PhotoPlaceholder.astro';
import { getLocalizedServices } from '@/content/services';
import { pageMetadata } from '@/content/metadata';
import { buildClinicSchema } from '@/lib/schema';
import { sectionRoutes } from '@/lib/siteArchitecture';
import { getLanguageSwitcherLinks, getSeoAlternateLinks } from '@/lib/siteArchitecture';

const locale = 'en' as const;
const metadata = pageMetadata.servicesOverview.en;
const services = getLocalizedServices(locale);
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.servicesOverview.en}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.servicesOverview, locale)}
  alternateLinks={getLanguageSwitcherLinks('servicesOverview', locale)}
  structuredData={structuredData}
>
  <section class="content-band">
    <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div class="section-copy">
        <Badge tone="accent">Services</Badge>
        <h1 class="display-title mt-5 max-w-2xl">Accurate diagnosis and multidisciplinary treatment planning.</h1>
        <p class="lead mt-4 max-w-2xl">
          Each service starts with a careful clinical assessment so the team can select the most
          appropriate treatment and coordinate the right expertise when the case needs an integrated
          approach.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-ink-soft">
          The cards below introduce the confirmed services and link to their individual pages,
          where you can find more detailed local content.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.contact.en}>Book a consultation</Button>
          <Button href={sectionRoutes.contact.en} variant="secondary">
            Request information
          </Button>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <PhotoPlaceholder
          eyebrow="Diagnosis photo"
          title="First visit and assessment"
          description="Add a clinic image from an assessment or clinical preparation moment."
          aspect="aspect-[4/3]"
        />
        <PhotoPlaceholder
          eyebrow="Treatment photo"
          title="Technology and precision"
          description="Add an approved detail of instruments, workflow, or operating room."
          aspect="aspect-[4/3]"
        />
        <div class="info-tile sm:col-span-2">
          <p class="eyebrow">Clinical pathway</p>
          <p class="mt-3 text-lg font-semibold text-ink">From diagnosis to the most suitable treatment.</p>
          <p class="mt-3 text-sm leading-7 text-ink-soft">
            Care plans are built around the patient&apos;s needs, with attention to function,
            aesthetics, comfort, and healing time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-band mt-6">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {services.map((service) => (
        <Card href={service.href} as="article" class="overflow-hidden p-0 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-clinic-soft)]">
          <PhotoPlaceholder
            eyebrow="Service image"
            title={service.label}
            description="Replace with a treatment photo or coherent clinical detail."
            aspect="aspect-[4/3]"
            class="rounded-b-none border-x-0 border-t-0"
          />
          <div class="p-5">
            <p class="eyebrow">Service</p>
            <h2 class="mt-3 text-xl font-semibold text-ink">{service.label}</h2>
            <p class="mt-3 text-sm leading-7 text-ink-soft">{service.summary}</p>
            <p class="mt-4 text-sm leading-7 text-ink-soft">{service.details}</p>
            <p class="mt-5 text-sm font-semibold text-clinic-900">Open the dedicated page</p>
          </div>
        </Card>
      ))}
    </div>
  </section>

  <BeforeAfterSection locale={locale} />

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.94fr_1.06fr]">
      <div class="info-tile">
        <p class="eyebrow">Contact</p>
        <p class="mt-3 text-lg font-semibold text-ink">Need help choosing the right service?</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          We can point you toward the most suitable service and explain the first steps in the
          treatment journey.
        </p>
      </div>
      <div class="info-tile">
        <p class="eyebrow">Next step</p>
        <p class="mt-3 text-lg font-semibold text-ink">Contact us for an initial assessment or more details.</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={sectionRoutes.contact.en}>Book a consultation</Button>
          <Button href={sectionRoutes.contact.en} variant="secondary">
            Request information
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
