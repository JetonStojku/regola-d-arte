---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BeforeAfterSection from '@/components/BeforeAfterSection.astro';
import ContactCtaBand from '@/components/sections/ContactCtaBand.astro';
import HeroImageSection from '@/components/sections/HeroImageSection.astro';
import ServiceRowListSection from '@/components/sections/ServiceRowListSection.astro';
import { getLocalizedServices } from '@/content/services';
import { pageMetadata } from '@/content/metadata';
import { buildClinicSchema } from '@/lib/schema';
import { sectionRoutes } from '@/lib/siteArchitecture';
import { getLanguageSwitcherLinks, getSeoAlternateLinks } from '@/lib/siteArchitecture';

const locale = 'en' as const;
const metadata = pageMetadata.servicesOverview.en;
const services = getLocalizedServices(locale);
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.servicesOverview.en}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.servicesOverview, locale)}
  alternateLinks={getLanguageSwitcherLinks('servicesOverview', locale)}
  structuredData={structuredData}
>
  <HeroImageSection
    eyebrow="Services"
    title="Accurate diagnosis and multidisciplinary treatment planning."
    intro="Each service starts with a careful clinical assessment so the team can select the most appropriate treatment and coordinate the right expertise when the case needs an integrated approach."
    note="The list below introduces the confirmed services and links to their individual pages, where you can find more detailed local content."
    primaryCta={{ label: 'Book a consultation', href: sectionRoutes.contact.en }}
    secondaryCta={{ label: 'Request information', href: sectionRoutes.contact.en, variant: 'secondary' }}
    image={{
      src: '/brand/homepage-hero.jpg',
      alt: 'Modern dental clinic with a structured treatment pathway',
      width: 1280,
      height: 720,
      sizes: '(min-width: 1024px) 35rem, 100vw',
      widths: [640, 960, 1280],
      loading: 'eager',
      fetchpriority: 'high',
      class: 'h-[22rem] w-full object-cover object-center',
    }}
    supportingPlaceholders={[
      {
        eyebrow: 'Diagnosis photo',
        title: 'First visit and assessment',
        description: 'Add a clinic image from an assessment or clinical preparation moment.',
        aspect: 'aspect-[4/3]',
      },
      {
        eyebrow: 'Treatment photo',
        title: 'Technology and precision',
        description: 'Add an approved detail of instruments, workflow, or operating room.',
        aspect: 'aspect-[4/3]',
      },
    ]}
  />

  <ServiceRowListSection
    eyebrow="Service overview"
    title="From diagnosis to the most suitable treatment."
    intro="The list follows the confirmed services and points to the individual pages, without turning every item into a card."
    services={services}
  />

  <BeforeAfterSection locale={locale} />

  <ContactCtaBand
    eyebrow="Contact"
    title="Need help choosing the right service?"
    intro="We can point you toward the most suitable service and explain the first steps in the treatment journey."
    note="Contact us for an initial assessment or more details."
    primaryCta={{ label: 'Book a consultation', href: sectionRoutes.contact.en }}
    secondaryCta={{ label: 'Request information', href: sectionRoutes.contact.en, variant: 'secondary' }}
  />
</BaseLayout>
