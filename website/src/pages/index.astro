---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Regola D'arte"
  description="Static Astro project setup for the Regola D'arte dentistry website."
>
  <main class="mx-auto min-h-screen max-w-4xl px-6 py-20">
    <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Project setup</p>
    <h1 class="mt-4 text-4xl font-semibold text-slate-950">Regola D'arte</h1>
    <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-700">
      Astro and Tailwind are configured here as the foundation for the multilingual clinic site.
    </p>
  </main>
</BaseLayout>
