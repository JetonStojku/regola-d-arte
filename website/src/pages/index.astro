---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { commonLabels } from '@/content/common';
import { navigationContent } from '@/content/navigation';
import { metaContent, rootGatewayPageContent, serviceOverviewCardList } from '@/content/pages';
import {
  getLocalizedServiceLinks,
  localeMeta,
  primaryLocale,
  rootRouteBehavior,
  sectionRoutes,
  type Locale,
} from '@/lib/siteArchitecture';

const localeChoices: Locale[] = ['it', 'en'];
const gatewayContent = rootGatewayPageContent.it;
const metadata = metaContent.rootGateway.it;
const serviceList = getLocalizedServiceLinks(primaryLocale);
const routeRows = [
  { label: commonLabels.routeItems.home.it, hrefs: sectionRoutes.home },
  { label: commonLabels.routeItems.about.it, hrefs: sectionRoutes.about },
  { label: commonLabels.routeItems.servicesOverview.it, hrefs: sectionRoutes.servicesOverview },
  { label: commonLabels.routeItems.contact.it, hrefs: sectionRoutes.contact },
  { label: commonLabels.routeItems.notFound.it, hrefs: sectionRoutes.notFound },
];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={primaryLocale}
  canonical={rootRouteBehavior.path}
  robots="noindex,follow"
>
  <main class="mx-auto flex min-h-screen max-w-5xl items-center px-6 py-16">
    <section class="grid w-full gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="space-y-6">
        <p class="text-sm uppercase tracking-[0.24em] text-slate-500">{gatewayContent.eyebrow}</p>
        <div class="space-y-4">
          <h1 class="text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">
            {gatewayContent.title}
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-slate-700">{gatewayContent.intro}</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {localeChoices.map((locale, index) => (
            <a
              href={sectionRoutes.home[locale]}
              class:list={[
                'rounded-2xl border p-5 transition',
                locale === primaryLocale
                  ? 'border-slate-950 bg-slate-950 text-white'
                  : 'border-slate-200 bg-white text-slate-900 hover:border-slate-400',
              ]}
            >
              <p class="text-sm uppercase tracking-[0.2em] opacity-70">
                {localeMeta[locale].label}
              </p>
              <p class="mt-3 text-xl font-semibold">
                {index === 0 ? gatewayContent.primaryPathLabel : gatewayContent.secondaryPathLabel}
              </p>
              <p class="mt-1 text-xs uppercase tracking-[0.18em] opacity-70">
                {gatewayContent.localePathLabel}
              </p>
              <p class="mt-2 text-sm leading-6 opacity-80">{sectionRoutes.home[locale]}</p>
            </a>
          ))}
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white p-6">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
            {gatewayContent.urlMapTitle}
          </p>
          <ul class="mt-4 grid gap-3 text-sm text-slate-700 sm:grid-cols-2">
            {routeRows.map((row) => (
              <li>
                {row.label}: {row.hrefs.it} | {row.hrefs.en}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <aside class="space-y-6 rounded-3xl border border-slate-200 bg-slate-50 p-6">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
            {gatewayContent.navigationTitle}
          </p>
          <div class="mt-4 space-y-3 text-sm text-slate-700">
            <p>
              {commonLabels.primaryNavigation.it}:
              {navigationContent.primary.it.map((item) => ` ${item.label} -> ${item.href}`).join(' | ')}
            </p>
            <p>
              {commonLabels.primaryNavigation.en}:
              {navigationContent.primary.en.map((item) => ` ${item.label} -> ${item.href}`).join(' | ')}
            </p>
            <p>
              {commonLabels.footerNavigation.it}:
              {navigationContent.footer.it.map((item) => ` ${item.label} -> ${item.href}`).join(' | ')}
            </p>
            <p>
              {commonLabels.footerNavigation.en}:
              {navigationContent.footer.en.map((item) => ` ${item.label} -> ${item.href}`).join(' | ')}
            </p>
          </div>
        </div>

        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
            {gatewayContent.serviceTitle}
          </p>
          <ul class="mt-4 space-y-3 text-sm text-slate-700">
            {serviceList.map((service) => (
              <li>
                <span class="font-medium text-slate-950">{service.label}</span>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-slate-500">
                  {service.href}
                </div>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
            {gatewayContent.internalLinksTitle}
          </p>
          <p class="mt-4 text-sm leading-6 text-slate-700">{gatewayContent.defaultPathNote}</p>
        </div>

        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
            {gatewayContent.rootTitle}
          </p>
          <p class="mt-4 text-sm leading-6 text-slate-700">
            {rootRouteBehavior.type} -> {rootRouteBehavior.destination}
          </p>
        </div>

        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
            {gatewayContent.plannedPagesTitle}
          </p>
          <ul class="mt-4 space-y-2 text-sm text-slate-700">
            {serviceOverviewCardList.it.map((service) => (
              <li>
                {service.label}: {service.href}
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>
