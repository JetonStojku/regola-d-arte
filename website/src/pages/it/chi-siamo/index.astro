---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import PhotoPlaceholder from '@/components/PhotoPlaceholder.astro';
import ResponsiveImage from '@/components/ui/ResponsiveImage.astro';
import { pageMetadata } from '@/content/metadata';
import { navigationContent } from '@/content/navigation';
import { teamSectionContent } from '@/content/pages';
import { buildClinicSchema } from '@/lib/schema';
import { sectionRoutes } from '@/lib/siteArchitecture';
import { getLanguageSwitcherLinks, getSeoAlternateLinks } from '@/lib/siteArchitecture';

const locale = 'it' as const;
const metadata = pageMetadata.about.it;
const teamContent = teamSectionContent.it;
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.about.it}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.about, locale)}
  alternateLinks={getLanguageSwitcherLinks('about', locale)}
  structuredData={structuredData}
>
  <section class="content-band">
    <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div class="section-copy">
        <Badge tone="accent">Chi siamo</Badge>
        <h1 class="display-title mt-5 max-w-2xl">Regola D&apos;arte, il vostro sorriso, la nostra arte</h1>
        <p class="lead mt-4 max-w-2xl">
          Crediamo che ogni sorriso meriti attenzione, precisione e bellezza. Per questo uniamo
          competenza clinica, estetica, scienza e umanità in un percorso di cura personalizzato.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-ink-soft">
          La nostra filosofia si basa sulla precisione dell&apos;intervento, sulla qualità dei
          materiali e sull&apos;attenzione a biomeccanica, occlusione e funzione, per risultati
          funzionali, armonici e duraturi.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.servicesOverview.it}>{navigationContent.primary.it[1].label}</Button>
          <Button href={sectionRoutes.contact.it} variant="secondary">
            {navigationContent.primary.it[2].label}
          </Button>
        </div>

      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="visual-frame sm:col-span-2">
            <ResponsiveImage
              src="/brand/about-doctor.jpg"
              alt="Dott. Genti Dylgjeri in uno studio odontoiatrico moderno"
              class="h-[22rem] w-full object-cover object-center"
              width={1280}
              height={720}
              sizes="(min-width: 1024px) 35rem, 100vw"
              widths={[640, 960, 1280]}
              loading="eager"
              fetchpriority="high"
            />
        </div>
        <div class="visual-frame">
            <ResponsiveImage
              src="/brand/about-clinic.jpg"
              alt="Equipe odontoiatrica durante una seduta di cura in uno studio moderno"
              class="h-56 w-full object-cover object-center"
              width={800}
              height={533}
              sizes="(min-width: 1024px) 35rem, 100vw"
              widths={[480, 800, 1200]}
              loading="eager"
              fetchpriority="high"
            />
        </div>
        <PhotoPlaceholder
          eyebrow="Foto studio"
          title="Dettaglio professionale"
          description="Inserire una foto di strumentazione, sala o dettaglio che comunichi precisione."
        />
      </div>
    </div>
  </section>

  <section class="content-band mt-6">
    <div class="grid gap-4 lg:grid-cols-3">
      <div class="info-tile">
        <p class="eyebrow">Precisione e funzione</p>
        <p class="mt-3 text-lg font-semibold text-ink">Ogni piano parte da una diagnosi accurata.</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          I trattamenti sono preceduti da una valutazione attenta e costruiti con un approccio
          multidisciplinare, sempre orientato al caso specifico.
        </p>
      </div>
      <div class="info-tile">
        <p class="eyebrow">Estetica e scienza</p>
        <p class="mt-3 text-lg font-semibold text-ink">La bellezza del sorriso segue criteri clinici solidi.</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          La cura estetica non è separata dalla funzione: lavoriamo per risultati naturali,
          confortevoli e stabili nel tempo.
        </p>
      </div>
      <div class="info-tile">
        <p class="eyebrow">Servizi confermati</p>
        <p class="mt-3 text-lg font-semibold text-ink">Dal controllo preventivo ai trattamenti più complessi.</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          L&apos;offerta copre conservativa ed endodonzia, chirurgia orale e implantologia,
          ortodonzia, estetica dentale e igiene orale professionale.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={sectionRoutes.servicesOverview.it}>{navigationContent.primary.it[1].label}</Button>
          <Button href={sectionRoutes.contact.it} variant="secondary">
            {navigationContent.primary.it[2].label}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr]">
      <div class="section-copy">
        <p class="eyebrow">{teamContent.eyebrow}</p>
        <h2 class="section-title mt-4">{teamContent.title}</h2>
        <p class="mt-4 text-sm leading-7 text-ink-soft">{teamContent.intro}</p>
        <p class="mt-4 rounded-2xl border border-border bg-canvas-soft/70 p-4 text-sm leading-7 text-ink-soft">
          {teamContent.fallbackNote}
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {teamContent.members.map((member) => (
          <Card class="overflow-hidden p-0">
            <ResponsiveImage
              src={member.photoSrc}
              alt={member.photoAlt}
              class="h-56 w-full object-cover object-center"
              width={member.photoSrc === '/brand/about-clinic.jpg' ? 800 : 1280}
              height={member.photoSrc === '/brand/about-clinic.jpg' ? 533 : 720}
              sizes="(min-width: 640px) 20rem, 100vw"
              widths={member.photoSrc === '/brand/about-clinic.jpg' ? [480, 800, 1200] : [640, 960, 1280]}
              loading="lazy"
            />
            <div class="p-5">
              <p class="text-lg font-semibold text-ink">{member.name ?? member.role}</p>
              <p class="mt-2 text-xs uppercase tracking-[0.18em] text-ink-soft">{member.role}</p>
              <p class="mt-3 text-sm leading-7 text-ink-soft">{member.summary}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <div class="info-tile mt-6">
      <p class="eyebrow">Contenuti mancanti</p>
      <p class="mt-3 text-sm leading-7 text-ink-soft">{teamContent.missingNote}</p>
    </div>
  </section>
</BaseLayout>
