---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Badge from "@/components/ui/Badge.astro";
import Card from "@/components/ui/Card.astro";
import DeferredEmbed from "@/components/ui/DeferredEmbed.astro";
import ContactForm from "@/components/ContactForm.astro";
import PhotoPlaceholder from "@/components/PhotoPlaceholder.astro";
import { contactPageContent } from "@/content/pages";
import { pageMetadata } from "@/content/metadata";
import { buildClinicSchema } from "@/lib/schema";
import { sectionRoutes } from "@/lib/siteArchitecture";
import {
  getLanguageSwitcherLinks,
  getSeoAlternateLinks,
} from "@/lib/siteArchitecture";

const locale = "it" as const;
const metadata = pageMetadata.contact.it;
const content = contactPageContent.it;
const structuredData = [
  buildClinicSchema(locale, metadata.description, { site: Astro.site }),
];
const facebookEmbedUrl = content.facebookPageHref
  ? `https://www.facebook.com/plugins/page.php?${new URLSearchParams({
      href: content.facebookPageHref,
      tabs: "timeline",
      width: "500",
      height: "700",
      small_header: "false",
      adapt_container_width: "true",
      hide_cover: "false",
      show_facepile: "true",
    }).toString()}`
  : null;
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.contact.it}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.contact, locale)}
  alternateLinks={getLanguageSwitcherLinks("contact", locale)}
  structuredData={structuredData}
>
  <section class="content-band">
    <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
      <div class="section-copy">
        <Badge tone="accent">{content.eyebrow}</Badge>
        <h1 class="display-title mt-5 max-w-2xl">{content.title}</h1>
        <p class="lead mt-4 max-w-2xl">{content.intro}</p>
        <p class="mt-4 max-w-xl text-sm leading-7 text-ink-soft">
          {content.fullAddress}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={content.directionsHref}
            class="button button--primary"
            target="_blank"
            rel="noreferrer"
          >
            {content.directionsLabel}
          </a>
          <a href={content.phoneHref} class="button button--secondary"
            >{content.phoneLabel}</a
          >
          <a
            href={content.whatsappHref}
            class="button button--ghost"
            target="_blank"
            rel="noreferrer"
          >
            {content.whatsappLabel}
          </a>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
          <div class="info-tile">
            <p class="eyebrow">{content.addressLabel}</p>
            <p class="mt-3 text-lg font-semibold text-ink">
              {content.addressLine}
            </p>
            <p class="mt-2 text-sm leading-7 text-ink-soft">
              {content.cityLine}
            </p>
            <div class="mt-5 space-y-3 text-sm leading-7 text-ink-soft">
              <p>
                <span class="font-semibold text-ink">{content.phoneLabel}:</span
                >
                <a href={content.phoneHref} class="ml-2 text-link"
                  >{content.phoneHref.replace("tel:", "")}</a
                >
              </p>
              <p>
                <span class="font-semibold text-ink">{content.emailLabel}:</span
                >
                <a href={content.emailHref} class="ml-2 text-link"
                  >{content.emailHref.replace("mailto:", "")}</a
                >
              </p>
            </div>
          </div>

          <div class="info-tile">
            <p class="eyebrow">{content.hoursLabel}</p>
            <dl class="mt-4 grid gap-2 text-sm leading-6 text-ink-soft">
              {
                content.openingHours.map((entry) => (
                  <div class="grid gap-1 border-b border-border/60 py-2 last:border-b-0 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center sm:gap-4">
                    <dt class="font-medium text-ink">{entry.day}</dt>
                    <dd>{entry.hours}</dd>
                  </div>
                ))
              }
            </dl>
          </div>

          <PhotoPlaceholder
            eyebrow="Foto esterno"
            title="Ingresso o riferimento visivo"
            description="Inserire una foto dell'ingresso o un dettaglio che aiuti a riconoscere lo studio."
            class="md:col-span-2"
            aspect="aspect-[16/7]"
          />
      </div>
    </div>
  </section>

  <ContactForm locale={locale} content={content} />

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="info-tile">
        <p class="eyebrow">{content.directionsLabel}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.fullAddress}</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          {content.directionsNote}
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a
            href={content.directionsHref}
            class="button button--primary"
            target="_blank"
            rel="noreferrer"
          >
            {content.directionsLabel}
          </a>
          <a
            href={content.mapListingHref}
            class="button button--secondary"
            target="_blank"
            rel="noreferrer"
          >
            {content.mapListingLabel}
          </a>
        </div>
        <p class="mt-4 text-xs leading-6 text-ink-soft">
          {content.missingNote}
        </p>
      </div>

      {
        content.mapEmbedUrl ? (
          <Card class="overflow-hidden p-0">
            <DeferredEmbed
              src={content.mapEmbedUrl}
              title={content.mapIframeTitle}
              eyebrow={content.mapEyebrow}
              heading={content.mapTitle}
              intro={content.mapIntro}
              loadLabel="Carica la mappa"
              openLabel={content.mapListingLabel}
              openHref={content.mapListingHref}
              note={content.mapFallbackNote}
              minHeightClass="min-h-[24rem]"
            />
          </Card>
        ) : (
          <Card tone="muted" class="p-6">
            <p class="eyebrow">{content.mapEyebrow}</p>
            <p class="mt-3 text-lg font-semibold text-ink">
              {content.mapTitle}
            </p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">
              {content.mapFallbackNote}
            </p>
          </Card>
        )
      }
    </div>
  </section>

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="info-tile">
        <p class="eyebrow">{content.facebookEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">
          {content.facebookTitle}
        </p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          {content.facebookIntro}
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          {
            content.facebookPageHref ? (
              <a
                href={content.facebookPageHref}
                class="button button--secondary"
                target="_blank"
                rel="noreferrer"
              >
                {content.facebookListingLabel}
              </a>
            ) : null
          }
        </div>
        {
          !content.facebookPageHref ? (
            <p class="mt-4 text-xs leading-6 text-ink-soft">
              {content.facebookMissingNote}
            </p>
          ) : null
        }
      </div>

      {
        facebookEmbedUrl ? (
          <Card class="overflow-hidden p-0">
            <DeferredEmbed
              src={facebookEmbedUrl}
              title={content.facebookIframeTitle}
              eyebrow={content.facebookEyebrow}
              heading={content.facebookTitle}
              intro={content.facebookIntro}
              loadLabel="Carica Facebook"
              openLabel={content.facebookListingLabel}
              openHref={content.facebookPageHref ?? ""}
              note={content.facebookFallbackNote}
              aspectRatio="16 / 12"
              minHeightClass="min-h-[32rem]"
            />
          </Card>
        ) : (
          <Card tone="muted" class="p-6">
            <p class="eyebrow">{content.facebookEyebrow}</p>
            <p class="mt-3 text-lg font-semibold text-ink">
              {content.facebookTitle}
            </p>
            <p class="mt-3 text-sm leading-7 text-ink-soft">
              {content.facebookFallbackNote}
            </p>
            {content.facebookPageHref ? (
              <a
                href={content.facebookPageHref}
                class="mt-5 inline-flex text-link text-sm font-semibold"
                target="_blank"
                rel="noreferrer"
              >
                {content.facebookListingLabel}
              </a>
            ) : null}
          </Card>
        )
      }
    </div>
  </section>

  <section class="content-band mt-6">
    <div class="grid gap-4 lg:grid-cols-3">
    <div class="info-tile">
      <p class="eyebrow">{content.legalDetailsTitle}</p>
      <dl class="mt-4 space-y-3 text-sm leading-7 text-ink-soft">
        <div>
          <dt class="font-semibold text-ink">{content.vatLabel}</dt>
          <dd>{content.vatNumber}</dd>
        </div>
        <div>
          <dt class="font-semibold text-ink">{content.directorLabel}</dt>
          <dd>{content.directorName}</dd>
        </div>
        <div>
          <dt class="font-semibold text-ink">{content.registerLabel}</dt>
          <dd>{content.registerNumber}</dd>
        </div>
      </dl>
    </div>

    <div id="privacy-policy" class="info-tile scroll-mt-28">
      <p class="eyebrow">{content.privacyPolicyTitle}</p>
      <p class="mt-3 text-lg font-semibold text-ink">
        {content.privacyPolicyTitle}
      </p>
      <p class="mt-3 text-sm leading-7 text-ink-soft">
        {content.privacyPolicyBody}
      </p>
    </div>

    <div id="cookie-policy" class="info-tile scroll-mt-28">
      <p class="eyebrow">{content.cookiePolicyTitle}</p>
      <p class="mt-3 text-lg font-semibold text-ink">
        {content.cookiePolicyTitle}
      </p>
      <p class="mt-3 text-sm leading-7 text-ink-soft">
        {content.cookiePolicyBody}
      </p>
    </div>
    </div>
  </section>
</BaseLayout>
