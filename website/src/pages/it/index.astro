---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BeforeAfterSection from '@/components/BeforeAfterSection.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import HeroImageSection from '@/components/sections/HeroImageSection.astro';
import PhotoPlaceholder from '@/components/PhotoPlaceholder.astro';
import { homePageContent, metaContent } from '@/content/pages';
import { navigationContent } from '@/content/navigation';
import { getLocalizedServices } from '@/content/services';
import { buildClinicSchema } from '@/lib/schema';
import {
  getLanguageSwitcherLinks,
  getSeoAlternateLinks,
  sectionRoutes,
} from '@/lib/siteArchitecture';

const locale = 'it' as const;
const content = homePageContent.it;
const metadata = metaContent.home.it;
const services = getLocalizedServices(locale).slice(0, 3);
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.home.it}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.home, locale)}
  alternateLinks={getLanguageSwitcherLinks('home', locale)}
  structuredData={structuredData}
>
  <HeroImageSection
    eyebrow={content.eyebrow}
    title={content.title}
    intro={content.intro}
    note={content.heroNote}
    primaryCta={{ label: content.heroPrimaryCta, href: sectionRoutes.servicesOverview.it }}
    secondaryCta={{ label: content.heroSecondaryCta, href: sectionRoutes.contact.it, variant: 'secondary' }}
    image={{
      src: '/brand/homepage-hero.jpg',
      alt: 'Dott. Genti Dylgjeri in uno studio odontoiatrico moderno',
      width: 1280,
      height: 720,
      sizes: '(min-width: 1024px) 35rem, 100vw',
      widths: [640, 960, 1280],
      loading: 'eager',
      fetchpriority: 'high',
      class: 'h-[22rem] w-full object-cover object-center',
    }}
    supportingPlaceholders={[
      {
        eyebrow: 'Foto studio',
        title: 'Dettaglio ambiente',
        description:
          'Inserire una foto luminosa della reception, sala operativa o dettaglio dello studio.',
      },
      {
        eyebrow: 'Foto team',
        title: 'Accoglienza',
        description: 'Inserire una foto del team o di un momento di accoglienza approvato.',
      },
    ]}
  />

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div class="section-copy">
        <p class="eyebrow">{content.servicesEyebrow}</p>
        <h2 class="section-title mt-4">{content.servicesTitle}</h2>
        <p class="mt-4 text-sm leading-7 text-ink-soft">{content.servicesIntro}</p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {services.map((service) => (
          <Card href={service.href} as="article" class="overflow-hidden p-0 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-clinic)]">
            <PhotoPlaceholder
              eyebrow="Immagine servizio"
              title={service.label}
              description="Sostituire con foto coerente con il trattamento."
              aspect="aspect-[4/3]"
              class="rounded-b-none border-x-0 border-t-0"
            />
            <div class="p-5">
              <p class="text-lg font-semibold text-ink">{service.label}</p>
              <p class="mt-3 text-sm leading-7 text-ink-soft">{service.summary}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <BeforeAfterSection locale={locale} />

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="info-tile">
        <p class="eyebrow">{content.storyEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.storyTitle}</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">{content.storyBody}</p>
      </div>
      <div class="info-tile">
        <p class="eyebrow">{content.trustEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.trustTitle}</p>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-ink-soft">
          {content.trustPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>
      <div class="info-tile">
        <p class="eyebrow">{content.contactEyebrow}</p>
        <p class="mt-3 text-lg font-semibold text-ink">{content.contactTitle}</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">{content.contactIntro}</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={sectionRoutes.contact.it}>{navigationContent.primary.it[2].label}</Button>
          <Button href={sectionRoutes.servicesOverview.it} variant="secondary">
            {navigationContent.primary.it[1].label}
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
