---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { commonLabels } from '@/content/common';
import { homePageContent, metaContent } from '@/content/pages';
import { navigationContent } from '@/content/navigation';
import {
  getLanguageSwitcherLinks,
  sectionRoutes,
} from '@/lib/siteArchitecture';

const locale = 'it' as const;
const content = homePageContent.it;
const metadata = metaContent.home.it;
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.home.it}
  alternateLinks={getLanguageSwitcherLinks('home', locale)}
  robots="noindex,follow"
>
  <main class="mx-auto min-h-screen max-w-4xl px-6 py-16">
    <p class="text-sm uppercase tracking-[0.24em] text-slate-500">{content.eyebrow}</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950">{content.title}</h1>
    <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-700">{content.intro}</p>

    <div class="mt-8 flex flex-wrap gap-3 text-sm">
      {navigationContent.primary.it.map((item) => (
        <a class="rounded-full border border-slate-300 px-4 py-2 text-slate-900" href={item.href}>
          {item.label}
        </a>
      ))}
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <p class="text-sm uppercase tracking-[0.2em] text-slate-500">{commonLabels.languageSwitcher.it}</p>
        <p class="mt-3 text-lg font-semibold text-slate-950">{content.routeLabel}</p>
        <p class="mt-2 text-sm text-slate-700">{sectionRoutes.home.it}</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <p class="text-sm uppercase tracking-[0.2em] text-slate-500">{content.navigationTitle}</p>
        <p class="mt-3 text-lg font-semibold text-slate-950">{commonLabels.primaryNavigation.it}</p>
        <p class="mt-2 text-sm text-slate-700">{content.homePathLabel}</p>
      </div>
    </div>
  </main>
</BaseLayout>
