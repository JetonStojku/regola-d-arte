---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import ResponsiveImage from '@/components/ui/ResponsiveImage.astro';
import { getLocalizedServiceContent, getServiceEntry, getServiceKeyByLocalizedSlug, serviceCatalog } from '@/content/services';
import { serviceMetadata } from '@/content/metadata';
import { buildClinicSchema, buildServiceSchema } from '@/lib/schema';
import { getOtherLocale, getSeoAlternateLinks, sectionRoutes } from '@/lib/siteArchitecture';

const locale = 'it' as const;
const slug = Astro.params.slug ?? '';
const serviceKey = getServiceKeyByLocalizedSlug(slug, locale);

if (!serviceKey) {
  return Astro.redirect(sectionRoutes.servicesOverview.it, 302);
}

const service = getServiceEntry(serviceKey);
const content = getLocalizedServiceContent(serviceKey, locale);
const metadata = serviceMetadata[serviceKey].it;
const heroIsClinicImage = service.images.hero.src === '/brand/about-clinic.jpg';
const heroImageWidth = heroIsClinicImage ? 800 : 1280;
const heroImageHeight = heroIsClinicImage ? 533 : 720;
const heroImageWidths = heroIsClinicImage ? [480, 800, 1200] : [640, 960, 1280];
const localizedAlternates = {
  it: service.paths.it,
  en: service.paths.en,
};
const structuredData = [
  buildClinicSchema(locale, metadata.description, { site: Astro.site }),
  buildServiceSchema(serviceKey, locale, metadata.description, { site: Astro.site }),
];

export function getStaticPaths() {
  return Object.entries(serviceCatalog).map(([, service]) => ({
    params: { slug: service.slugs.it },
  }));
}
---

<BaseLayout
  title={serviceMetadata[serviceKey].it.title}
  description={serviceMetadata[serviceKey].it.description}
  locale={locale}
  canonical={service.paths.it}
  hreflangLinks={getSeoAlternateLinks(localizedAlternates, locale)}
  alternateLinks={[{ locale: getOtherLocale(locale), href: service.paths.en, label: 'English', isCurrent: false }]}
  structuredData={structuredData}
>
  <section class="surface overflow-hidden">
    <div class="grid gap-0 lg:grid-cols-[1.02fr_0.98fr]">
      <div class="p-6 sm:p-8 lg:p-10">
        <Badge tone="accent">Servizio</Badge>
        <h1 class="display-title mt-5 max-w-2xl">{service.labels.it}</h1>
        <p class="lead mt-4 max-w-2xl">{content.summary}</p>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-ink-soft">{content.details}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.contact.it}>{content.ctas.primary}</Button>
          <Button href={sectionRoutes.servicesOverview.it} variant="secondary">
            Torna ai servizi
          </Button>
        </div>
      </div>
      <aside class="border-t border-border bg-canvas-soft/70 p-6 sm:p-8 lg:border-l lg:border-t-0">
        <Card class="overflow-hidden p-0">
          <ResponsiveImage
            src={service.images.hero.src}
            alt={service.images.hero.alt.it}
            class="h-80 w-full object-cover object-center"
            width={heroImageWidth}
            height={heroImageHeight}
            sizes="(min-width: 1024px) 35rem, 100vw"
            widths={heroImageWidths}
            loading="eager"
            fetchpriority="high"
          />
        </Card>
      </aside>
    </div>
  </section>

  <section class="surface mt-6 p-6 sm:p-8 lg:p-10">
    <div class="grid gap-4 lg:grid-cols-2">
      {content.sections.map((section) => (
        <Card class="p-5">
          <p class="eyebrow">{section.eyebrow.it}</p>
          <h2 class="mt-3 text-xl font-semibold text-ink">{section.title.it}</h2>
          <p class="mt-3 text-sm leading-7 text-ink-soft">{section.body.it}</p>
          {section.bullets?.it && (
            <ul class="mt-4 space-y-2 text-sm leading-6 text-ink-soft">
              {section.bullets.it.map((bullet) => <li>• {bullet}</li>)}
            </ul>
          )}
        </Card>
      ))}
    </div>
  </section>

  <section class="surface mt-6 p-6 sm:p-8 lg:p-10">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <Card class="p-5">
        <p class="eyebrow">Domande frequenti</p>
        <div class="mt-4 space-y-4">
          {content.faqs.map((faq) => (
            <div>
              <p class="font-semibold text-ink">{faq.question.it}</p>
              <p class="mt-2 text-sm leading-7 text-ink-soft">{faq.answer.it}</p>
            </div>
          ))}
        </div>
      </Card>
      <Card tone="muted" class="p-5">
        <p class="eyebrow">{content.ctas.related}</p>
        <p class="mt-3 text-lg font-semibold text-ink">Scopri anche i servizi collegati.</p>
        <div class="mt-5 flex flex-wrap gap-3">
          {content.relatedServices.map((relatedServiceKey) => (
            <Button href={getServiceEntry(relatedServiceKey).paths.it} variant="secondary">
              {getServiceEntry(relatedServiceKey).labels.it}
            </Button>
          ))}
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
