---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BeforeAfterSection from '@/components/BeforeAfterSection.astro';
import ContactCtaBand from '@/components/sections/ContactCtaBand.astro';
import HeroImageSection from '@/components/sections/HeroImageSection.astro';
import ServiceRowListSection from '@/components/sections/ServiceRowListSection.astro';
import { getLocalizedServices } from '@/content/services';
import { pageMetadata } from '@/content/metadata';
import { buildClinicSchema } from '@/lib/schema';
import { sectionRoutes } from '@/lib/siteArchitecture';
import { getLanguageSwitcherLinks, getSeoAlternateLinks } from '@/lib/siteArchitecture';

const locale = 'it' as const;
const metadata = pageMetadata.servicesOverview.it;
const services = getLocalizedServices(locale);
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.servicesOverview.it}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.servicesOverview, locale)}
  alternateLinks={getLanguageSwitcherLinks('servicesOverview', locale)}
  structuredData={structuredData}
>
  <HeroImageSection
    eyebrow="Servizi"
    title="Diagnosi accurata e piano di cura multidisciplinare."
    intro="Ogni servizio parte da una valutazione clinica precisa, utile a definire il trattamento più adatto e a collegare le competenze necessarie quando il caso richiede un approccio integrato."
    note="Le schede qui sotto introducono i servizi confermati e rimandano alle relative pagine individuali, dove trovi contenuti locali più dettagliati."
    primaryCta={{ label: 'Prenota un confronto', href: sectionRoutes.contact.it }}
    secondaryCta={{ label: 'Richiedi informazioni', href: sectionRoutes.contact.it, variant: 'secondary' }}
    image={{
      src: '/brand/homepage-hero.jpg',
      alt: 'Studio odontoiatrico moderno con percorso di cura organizzato',
      width: 1280,
      height: 720,
      sizes: '(min-width: 1024px) 35rem, 100vw',
      widths: [640, 960, 1280],
      loading: 'eager',
      fetchpriority: 'high',
      class: 'h-[22rem] w-full object-cover object-center',
    }}
    supportingPlaceholders={[
      {
        eyebrow: 'Foto diagnosi',
        title: 'Prima visita e valutazione',
        description:
          "Inserire un'immagine dello studio durante una valutazione o una preparazione clinica.",
        aspect: 'aspect-[4/3]',
      },
      {
        eyebrow: 'Foto trattamento',
        title: 'Tecnologia e precisione',
        description: 'Inserire un dettaglio di strumenti, workflow o ambiente operativo approvato.',
        aspect: 'aspect-[4/3]',
      },
    ]}
  />

  <ServiceRowListSection
    eyebrow="Panoramica servizi"
    title="Dalla diagnosi alla terapia più adatta."
    intro="La lista segue i servizi confermati e rimanda alle relative pagine individuali, senza trasformare ogni voce in una card."
    services={services}
  />

  <BeforeAfterSection locale={locale} />

  <ContactCtaBand
    eyebrow="Contatto"
    title="Hai bisogno di orientarti tra i servizi?"
    intro="Possiamo indicarti il servizio più adatto e spiegare i passaggi iniziali del percorso."
    note="Contattaci per una prima valutazione o per maggiori dettagli."
    primaryCta={{ label: 'Prenota un confronto', href: sectionRoutes.contact.it }}
    secondaryCta={{ label: 'Richiedi informazioni', href: sectionRoutes.contact.it, variant: 'secondary' }}
  />
</BaseLayout>
