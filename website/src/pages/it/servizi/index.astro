---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BeforeAfterSection from '@/components/BeforeAfterSection.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import PhotoPlaceholder from '@/components/PhotoPlaceholder.astro';
import { getLocalizedServices } from '@/content/services';
import { pageMetadata } from '@/content/metadata';
import { buildClinicSchema } from '@/lib/schema';
import { sectionRoutes } from '@/lib/siteArchitecture';
import { getLanguageSwitcherLinks, getSeoAlternateLinks } from '@/lib/siteArchitecture';

const locale = 'it' as const;
const metadata = pageMetadata.servicesOverview.it;
const services = getLocalizedServices(locale);
const structuredData = [buildClinicSchema(locale, metadata.description, { site: Astro.site })];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.servicesOverview.it}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.servicesOverview, locale)}
  alternateLinks={getLanguageSwitcherLinks('servicesOverview', locale)}
  structuredData={structuredData}
>
  <section class="content-band">
    <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div class="section-copy">
        <Badge tone="accent">Servizi</Badge>
        <h1 class="display-title mt-5 max-w-2xl">Diagnosi accurata e piano di cura multidisciplinare.</h1>
        <p class="lead mt-4 max-w-2xl">
          Ogni servizio parte da una valutazione clinica precisa, utile a definire il trattamento
          piu adatto e a collegare le competenze necessarie quando il caso richiede un approccio
          integrato.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-ink-soft">
          Le schede qui sotto introducono i servizi confermati e rimandano alle relative pagine
          individuali, dove trovi contenuti locali piu dettagliati.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={sectionRoutes.contact.it}>Prenota un confronto</Button>
          <Button href={sectionRoutes.contact.it} variant="secondary">
            Richiedi informazioni
          </Button>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <PhotoPlaceholder
          eyebrow="Foto diagnosi"
          title="Prima visita e valutazione"
          description="Inserire un'immagine dello studio durante una valutazione o una preparazione clinica."
          aspect="aspect-[4/3]"
        />
        <PhotoPlaceholder
          eyebrow="Foto trattamento"
          title="Tecnologia e precisione"
          description="Inserire un dettaglio di strumenti, workflow o ambiente operativo approvato."
          aspect="aspect-[4/3]"
        />
        <div class="info-tile sm:col-span-2">
          <p class="eyebrow">Percorso clinico</p>
          <p class="mt-3 text-lg font-semibold text-ink">Dalla diagnosi alla terapia piu adatta.</p>
          <p class="mt-3 text-sm leading-7 text-ink-soft">
            Il percorso di cura viene costruito sui bisogni del paziente, con attenzione a funzione,
            estetica, comfort e tempi di guarigione.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-band mt-6">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {services.map((service) => (
        <Card href={service.href} as="article" class="overflow-hidden p-0 transition hover:-translate-y-0.5 hover:shadow-[var(--shadow-clinic-soft)]">
          <PhotoPlaceholder
            eyebrow="Immagine servizio"
            title={service.label}
            description="Sostituire con foto del trattamento o dettaglio clinico coerente."
            aspect="aspect-[4/3]"
            class="rounded-b-none border-x-0 border-t-0"
          />
          <div class="p-5">
            <p class="eyebrow">Servizio</p>
            <h2 class="mt-3 text-xl font-semibold text-ink">{service.label}</h2>
            <p class="mt-3 text-sm leading-7 text-ink-soft">{service.summary}</p>
            <p class="mt-4 text-sm leading-7 text-ink-soft">{service.details}</p>
            <p class="mt-5 text-sm font-semibold text-clinic-900">Apri la pagina dedicata</p>
          </div>
        </Card>
      ))}
    </div>
  </section>

  <BeforeAfterSection locale={locale} />

  <section class="content-band mt-6">
    <div class="grid gap-6 lg:grid-cols-[0.94fr_1.06fr]">
      <div class="info-tile">
        <p class="eyebrow">Contatto</p>
        <p class="mt-3 text-lg font-semibold text-ink">Hai bisogno di orientarti tra i servizi?</p>
        <p class="mt-3 text-sm leading-7 text-ink-soft">
          Possiamo indicarti il servizio piu adatto e spiegare i passaggi iniziali del percorso.
        </p>
      </div>
      <div class="info-tile">
        <p class="eyebrow">Prossimo passo</p>
        <p class="mt-3 text-lg font-semibold text-ink">Contattaci per una prima valutazione o per maggiori dettagli.</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={sectionRoutes.contact.it}>Prenota un confronto</Button>
          <Button href={sectionRoutes.contact.it} variant="secondary">
            Richiedi informazioni
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
