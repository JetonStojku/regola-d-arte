---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BeforeAfterSection from "@/components/BeforeAfterSection.astro";
import ContactCtaBand from "@/components/sections/ContactCtaBand.astro";
import HeroImageSection from "@/components/sections/HeroImageSection.astro";
import ServiceRowListSection from "@/components/sections/ServiceRowListSection.astro";
import { getLocalizedServices } from "@/content/services";
import { pageMetadata } from "@/content/metadata";
import { buildClinicSchema } from "@/lib/schema";
import { sectionRoutes } from "@/lib/siteArchitecture";
import {
  getLanguageSwitcherLinks,
  getSeoAlternateLinks,
} from "@/lib/siteArchitecture";

const locale = "it" as const;
const metadata = pageMetadata.servicesOverview.it;
const services = getLocalizedServices(locale);
const structuredData = [
  buildClinicSchema(locale, metadata.description, { site: Astro.site }),
];
---

<BaseLayout
  title={metadata.title}
  description={metadata.description}
  locale={locale}
  canonical={sectionRoutes.servicesOverview.it}
  hreflangLinks={getSeoAlternateLinks(sectionRoutes.servicesOverview, locale)}
  alternateLinks={getLanguageSwitcherLinks("servicesOverview", locale)}
  structuredData={structuredData}
>
  <HeroImageSection
    titleTag="h1"
    eyebrow="Servizi"
    title="Dal consulto al trattamento più adatto."
    intro="I trattamenti confermati sono presentati come una lista essenziale, con sintesi chiare e link alle pagine locali dedicate."
    note="Una sola intestazione principale e contenuti collegati ai dati del catalogo."
    primaryCta={{
      label: "Prenota un confronto",
      href: sectionRoutes.contact.it,
    }}
    image={{
      src: "/brand/homepage-hero.jpg",
      alt: "Studio odontoiatrico moderno con percorso di cura organizzato",
      width: 1280,
      height: 720,
      sizes: "(min-width: 1024px) 35rem, 100vw",
      widths: [640, 960, 1280],
      loading: "eager",
      fetchpriority: "high",
      class: "h-[22rem] w-full object-cover object-center",
    }}
  />

  <ServiceRowListSection
    eyebrow="Panoramica servizi"
    title="Servizi confermati e collegati alle pagine locali."
    intro="Ogni riga mostra titolo, sintesi, dettagli e immagine di riferimento, sempre dai dati di contenuto."
    note={`${String(services.length).padStart(2, "0")} servizi confermati`}
    locale={locale}
    services={services}
  />

  <ContactCtaBand
    eyebrow="Contatto"
    title="Hai bisogno di capire da dove iniziare?"
    intro="Possiamo indicarti il servizio più adatto e spiegare i passaggi iniziali del percorso."
    note="Contattaci per una prima valutazione o per maggiori dettagli."
    primaryCta={{
      label: "Prenota un confronto",
      href: sectionRoutes.contact.it,
    }}
    secondaryCta={{
      label: "Richiedi informazioni",
      href: sectionRoutes.contact.it,
      variant: "secondary",
    }}
  />

  <BeforeAfterSection locale={locale} />
</BaseLayout>
